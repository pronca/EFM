            </column>
            <column name="END_DATE" type="DATE" remarks="END_DATE">
                <constraints nullable="false"/>
            </column>
            <column name="CREATION_DATE" type="DATE" remarks="CREATION_DATE">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="FM_VERSION" columnNames="ID"/>


        <createTable tableName="FM_DATA_SOURCE" remarks="FM_DATA_SOURCE">
            <column name="ID" type="VARCHAR(64)" remarks="Identificativo">
                <constraints nullable="false"/>
            </column>
            <column name="NAME" type="VARCHAR(64)" remarks="Nome">
                <constraints nullable="false"/>
            </column>
            <column name="HOSTNAME" type="VARCHAR(64)" remarks="Hostname">
                <constraints nullable="false"/>
            </column>
            <column name="PORT" type="VARCHAR(10)" remarks="Porta">
                <constraints nullable="false"/>
            </column>
            <column name="SERVICE_NAME" type="VARCHAR(64)" remarks="Service Name">
                <constraints nullable="false"/>
            </column>
            <column name="DRIVER" type="VARCHAR(64)" remarks="Driver Database">
                <constraints nullable="false"/>
            </column>
            <column name="USERNAME" type="VARCHAR(64)" remarks="Username">
                <constraints nullable="false"/>
            </column>
            <column name="PASSWORD" type="VARCHAR(64)" remarks="Password">
                <constraints nullable="false"/>
            </column>
            <column name="ENABLED" type="BOOLEAN" defaultValueBoolean="true" remarks="Stato Datasource">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="FM_DATA_SOURCE" columnNames="ID"/>


        <createTable tableName="FM_DRIVER" remarks="FM_DRIVER">
            <column name="ID" type="VARCHAR(64)" remarks="Identificativo">
                <constraints nullable="false"/>
            </column>
            <column name="NAME" type="VARCHAR(64)" remarks="Nome">
                <constraints nullable="false"/>
            </column>
            <column name="DESCRIPTION" type="VARCHAR(255)" remarks="Descrizione">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="FM_DRIVER" columnNames="ID"/>


        <createTable tableName="FM_FLOW_TABLE_DATA_SOURCE" remarks="FM_FLOW_TABLE_DATA_SOURCE">
            <column name="ID" type="VARCHAR(64)" remarks="Identificativo">
                <constraints nullable="false"/>
            </column>
            <column name="FLOW_TABLE" type="VARCHAR(64)" remarks="Identificativo Flow Table">
                <constraints nullable="false"/>
            </column>
            <column name="DATA_SOURCE" type="VARCHAR(64)" remarks="Identificativo Data Source">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="FM_FLOW_TABLE_DATA_SOURCE" columnNames="ID"/>


        <createTable tableName="FM_FLOW_VERSION" remarks="FM_FLOW_VERSION">
            <column name="ID" type="VARCHAR(64)" remarks="Identificativo">
                <constraints nullable="false"/>
            </column>
            <column name="FLOW" type="VARCHAR(64)" remarks="Identificativo Flusso">
                <constraints nullable="false"/>
            </column>
            <column name="VERSION" type="VARCHAR(64)" remarks="Identificativo Versione">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="FM_FLOW_VERSION" columnNames="ID"/>


        <addForeignKeyConstraint baseColumnNames="FLOW_VERSION"
                             baseTableName="FM_FLOW_TABLE"
                             constraintName="FK_FM_FLOW_TABLE_FM_FLOW"
                             deferrable="true"
                             initiallyDeferred="true"
                             onDelete="CASCADE"
                             onUpdate="RESTRICT"
                             referencedColumnNames="ID"
                             referencedTableName="FM_FLOW_VERSION"/>

        <addForeignKeyConstraint baseColumnNames="FIELD_TYPE"
