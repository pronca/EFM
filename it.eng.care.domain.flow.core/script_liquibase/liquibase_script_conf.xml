        <addForeignKeyConstraint baseColumnNames="DATA_SOURCE"
                                 baseTableName="FM_FLOW_TABLE_DATA_SOURCE"
                                 constraintName="FK_FM_FLOW_TABLE_DATA_SOURCE_1"
                                 deferrable="true"
                                 initiallyDeferred="true"
                                 onDelete="CASCADE"
                                 onUpdate="RESTRICT"
                                 referencedColumnNames="ID"
