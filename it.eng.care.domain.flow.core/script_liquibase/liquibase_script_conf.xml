                                 constraintName="FK_FM_FLOW_TABLE_FIELD_FM_FLOW_TABLE"
                                 deferrable="true"
                                 initiallyDeferred="true"
                                 onDelete="CASCADE"
                                 onUpdate="RESTRICT"
                                 referencedColumnNames="ID"
                                 referencedTableName="FM_FLOW_TABLE"/>

        <addForeignKeyConstraint baseColumnNames="VERSION"
                                 baseTableName="FM_FLOW_VERSION"
