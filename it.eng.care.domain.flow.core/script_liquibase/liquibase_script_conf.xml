<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
    	http://www.liquibase.org/xml/ns/dbchangelog
    	http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd"
        logicalFilePath="db/changelogs/2019"
>

    <changeSet id="2019" author="gennaro.damelio" failOnError="true" context="fm_flow" >
        <comment>FLOW TABLES</comment>

        <createTable tableName="FM_FLOW" remarks="FM_FLOW">
            <column name="ID" type="VARCHAR(64)" remarks="Identificativo">
                <constraints nullable="false"/>
            </column>
            <column name="CODE" type="VARCHAR(10)" remarks="Codice">
                <constraints nullable="false"/>
            </column>
            <column name="NAME" type="VARCHAR(255)" remarks="Nome">
                <constraints nullable="false"/>
            </column>
            <column name="DESCRIPTION" type="VARCHAR(255)" remarks="Descrizione">
                <constraints nullable="false"/>
            </column>
            <column name="STATUS" type="BOOLEAN" remarks="Stato">
                <constraints nullable="false"/>
            </column>
            <column name="REMOTE_SEND" type="BOOLEAN" remarks="Invio Remoto Ente Accoglienza">
                <constraints nullable="false"/>
            </column>
            <column name="UNIQUENESS" type="BOOLEAN" remarks="Controllo Univocità Estrazione Certificata">
                <constraints nullable="false"/>
            </column>
            <column name="SCHEDULING" type="BOOLEAN" remarks="Schedulazione">
                <constraints nullable="false"/>
            </column>
            <column name="PERIODICITY" type="VARCHAR(64)" remarks="Periodicità">
                <constraints nullable="false"/>
            </column>
            <column name="MONTHLY_DEADLINE" type="DATE" remarks="Giorno Scadenza Raccolta Mensile">
                <constraints nullable="false"/>
            </column>
            <column name="TYPE" type="VARCHAR(30)" remarks="Tipo flusso">
             	<constraints nullable="false"/>
             </column>
        </createTable>
        <addPrimaryKey tableName="FM_FLOW" columnNames="ID"/>

        <createTable tableName="FM_FLOW_TABLE" remarks="FM_FLOW_TABLE">
            <column name="ID" type="VARCHAR(64)" remarks="Identificativo">
                <constraints nullable="false"/>
            </column>
            <column name="NAME" type="VARCHAR(64)" remarks="Nome">
                <constraints nullable="false"/>
            </column>
            <column name="DESCRIPTION" type="VARCHAR(255)" remarks="Descrizione">
                <constraints nullable="false"/>
            </column>
            <column name="SECTION" type="INT" remarks="Sezione">
                <constraints nullable="false"/>
            </column>
            <column name="FLOW_VERSION" type="VARCHAR(64)" remarks="FLOW">
                <constraints nullable="false" />
            </column>
        </createTable>
        <addPrimaryKey tableName="FM_FLOW_TABLE" columnNames="ID"/>


        <createTable tableName="FM_FLOW_TABLE_FIELD" remarks="FM_FLOW_TABLE_FIELD">
            <column name="ID" type="VARCHAR(64)" remarks="Identificativo">
                <constraints nullable="false"/>
            </column>
            <column name="NAME" type="VARCHAR(64)" remarks="Codice">
                <constraints nullable="false"/>
            </column>
            <column name="DESCRIPTION" type="VARCHAR(255)" remarks="Descrizione">
                <constraints nullable="false"/>
            </column>
            <column name="FIELD_TYPE" type="VARCHAR(64)" remarks="FIELD_TYPE_ID">
                <constraints nullable="false"/>
            </column>
            <column name="POSITION" type="INT" remarks="Posizione">
                <constraints nullable="false"/>
            </column>
            <column name="IS_PK" type="BOOLEAN" defaultValueBoolean="false" remarks="IS_PK">
                <constraints nullable="false"/>
            </column>
            <column name="FLOW_TABLE" type="VARCHAR(64)" remarks="FLOW_TABLE_ID">
                <constraints nullable="false"/>
            </column>
            <column name="FLOW_TABLE_FIELD_ID" type="VARCHAR(64)" remarks="FLOW_TABLE_FIELD_ID">
            </column>
            <column name="LENGTH" type="INT" remarks="Lunghezza">
                <constraints nullable="false"/>
            </column>
            <column name="MANDATORY" type="BOOLEAN" defaultValueBoolean="false" remarks="Mandatory">
                <constraints nullable="false"/>
            </column>
            <column name="REG_EXP" type="VARCHAR(255)"  remarks="Espressione regolare">
                <constraints nullable="false"/>
            </column>
            <column name="IS_REFERENCE_DATE" type="BOOLEAN" defaultValueBoolean="false" remarks="Reference date">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="FM_FLOW_TABLE_FIELD" columnNames="ID"/>


        <createTable tableName="FM_FIELD_TYPE" remarks="FM_FIELD_TYPE">
            <column name="ID" type="VARCHAR(64)" remarks="Identificativo">
                <constraints nullable="false"/>
            </column>
            <column name="DESCRIPTION" type="VARCHAR(255)" remarks="Descrizione">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="FM_FIELD_TYPE" columnNames="ID"/>

        <createTable tableName="FM_VERSION" remarks="FM_VERSION">
            <column name="ID" type="VARCHAR(64)" remarks="Identificativo">
                <constraints nullable="false"/>
            </column>
            <column name="VERSION" type="VARCHAR(32)" remarks="Codice">
