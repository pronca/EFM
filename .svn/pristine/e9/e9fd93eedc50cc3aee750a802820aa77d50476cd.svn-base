        private String generateQuerySelect(List<String> pkList, String flowName, int flowSection, Boolean joinWithRegionReturns) {
        	String select = "t1.EXTRACTION_ID EXTRACTION_ID, ";
        	
        	String joinScarto = "";
        	
            for (String pKey : pkList) {
                select += "t1." + pKey + " " + pKey + ", ";
                joinScarto += "t1." + pKey + " = " + " t2." + pKey + " and ";
            }
            if (select.endsWith(", ")) {
                select = select.substring(0, select.length() - 2);
            }
        	
            select = "SELECT " + select;
            
            String from = " FROM FM_FLOW_" + flowName + "_REG_" + flowSection + " t1 ";
            String where = " WHERE t1.EXTRACTION_ID=?";
            
            if(joinWithRegionReturns) {
            	String cfgSuffixRegError = configuration.findByKeyId("suffix_reg_error").getValue();
            	String scarto = flowName + "_REG_" + cfgSuffixRegError + " t2 ";
            	
            	joinScarto += " t1.EXTRACTION_ID = t2.EXTRACTION_ID ";
            	
            	String inner = " (select min(t2.severity) from " + scarto + " where " + joinScarto + " ) SEVERITY_SCARTO_REG ";
            	select += ", " + inner;
            }
            
        	String SQL_SELECT_R = select + from + where;
        	
        	return SQL_SELECT_R;
        }
        
        private String generateQuerySelectRitorni(List<String> selectRegList, List<String> pkRegList, String flowName, int flowSection, Boolean joinWithRegionReturns) {
        	String select = "SELECT  t1.EXTRACTION_ID EXTRACTION_ID, ";
        	String joinScarto = " AND ";
        	String selectGroupBy = " GROUP BY t1.EXTRACTION_ID, ";
        	
        	for (String sel : selectRegList) {
                select += "t1." + sel + " " + sel + ", "; 
                selectGroupBy += "t1." + sel + ", ";
            }
            if (select.endsWith(", ")) {
                select = select.substring(0, select.length() - 2);
                selectGroupBy = selectGroupBy.substring(0, selectGroupBy.length() - 2);
            }
            
            String from = " FROM FM_FLOW_" + flowName + "_REG_" + flowSection + " t1 ";
            String where = " WHERE 1=1 ";
            
            if(joinWithRegionReturns) {
            	select += ", MIN(NVL(t2.severity,t1.STATUS_REGION)) SEVERITY_SCARTO_REG ";
            	
            	String cfgSuffixRegError = configuration.findByKeyId("suffix_reg_error").getValue();
            	from += "," + flowName + "_REG_" + cfgSuffixRegError + " t2 ";
            	
            	for (String pKey : pkRegList) {
                    joinScarto += "t1." + pKey + " = " + " t2." + pKey + "(+) AND ";
                }
            	joinScarto += " t1.EXTRACTION_ID = t2.EXTRACTION_ID(+) ";
            } else {
            	select += ", MIN(t1.STATUS_REGION) SEVERITY_SCARTO_REG ";
            }
            
            if (joinScarto.endsWith(" AND ")) {
            	joinScarto = joinScarto.substring(0, joinScarto.length() - 4);
    		}
            
            where += joinScarto;
            where += " AND t1.EXTRACTION_ID=?";
            
        	String SQL_SELECT_R = select + from + where + selectGroupBy;
        	
        	return SQL_SELECT_R;
        }
        
