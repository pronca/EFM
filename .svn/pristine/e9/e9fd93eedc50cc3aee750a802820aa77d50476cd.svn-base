    @Override
    public FlowExportRequestDO createEntity(FlowExportRequestDO flowExportDO) {
    	Integer id = sequenceService.next(FlowExportRequestDO.class);

        Date requestDate = new Date();
        flowExportDO.setId(id.toString());
        flowExportDO.setRequestDate(requestDate);
        flowExportDO.setRandomId(UUID.randomUUID().toString());

        State<String, String> state = stateMachineFlow.createStateMachine(flowExportDO.getRandomId(), "EXPORT");

        if (state == null) {
            return null;
        } else {
            flowExportDO.setStatus(state.getId());
        }

//        Flag Delete (0 = Inserimento)
        flowExportDO.setDeleted(0);
		flowExportDO = flowExportDAO.save(flowExportDO);

        return flowExportDO;
    }

    @Override
    public FlowExportRequestDO updateEntityRow(FlowExportRequestDO flowExportDO) {
        flowExportDO.setDeleted(0);
        flowExportDO = flowExportDAO.save(flowExportDO);

        return flowExportDO;
    }

    @Override
    public FlowExportRequestDO updateEntity(FlowExportRequestDO flowExportDO) {
    	
    	/*if(useFlowProfile && !flowManagerProfileService.checkFlowById(flowExportDO.getFlow().getId())) {
    		return flowExportDO;
    	}*/

        BaseSearchInput input = new BaseSearchInput();
        input.setValue("extractionID", flowExportDO.getId());
//        FlowConfigurationFilterFieldValueDO value = new FlowConfigurationFilterFieldValueDO();
//
//        FlowExportRequestDO exp = new FlowExportRequestDO();
//        exp.setId(flowExportDO.getId());
//        value.setFlowExportRequest(exp);
//
//        flowConfigurationFilterFieldValueDAO.deleteBy(input);

        List<FlowConfigurationFilterFieldValueDO> listValue = flowConfigurationFilterFieldValueDAO.cerca(input);

        for (FlowConfigurationFilterFieldValueDO values : listValue) {
            flowConfigurationFilterFieldValueDAO.deleteById(values.getId());
        }

        flowExportDO.setDeleted(0);
		flowExportDO = flowExportDAO.save(flowExportDO);

        return flowExportDO;
    }

    @Override
    public Pair<List<FlowExportRequestDO>, SearchInfo> retrieveAllFiltered(BaseSearchInput searchInput, Boolean useFlowProfile) {

        try {
            String stateId = searchInput.getValue("state").toString();
            String state = stateService.searchState(stateId);
            searchInput.setValue("stateName", state);
        } catch (Exception e) {

        }

        int limit = searchInput.getParam("limit");
        int offset = searchInput.getParam("offset");
        Pageable page =  PageRequest.of((offset / limit), limit);

        Long totalItems = flowExportDAO.countFlowExportByFilter(searchInput, useFlowProfile);

        List<FlowExportRequestDO> loList = flowExportDAO.cerca(searchInput, page, useFlowProfile);
        return Pair.of(loList, SearchInfos.create(totalItems));

    }
    
    @Override
    public void invocaJobTalendAnnullaPratica (String flowName, String versionName, Map<String, String> pk) {
		Thread thread = new Thread() {
			@Transactional
			public void run() {
				LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     JOB ANNULLAMENTO PRATICA: Inizio processo invocazione Talend Jar per annullamento pratica    >>>>>>>>>>>>>>>>>>>>>>>");
		    	
				BaseSearchInput poInput = new BaseSearchInput();
				poInput.setValue("flowNameEqual", flowName);
				poInput.setValue("versionNameEqual", versionName);
				List<FlowTableDO> tables = flowTableDAO.cerca(poInput);
				
				FlowTableDO table = tables.stream().filter(t -> t.getSection().equals(0)).findAny().get();
				
		    	// 1. cerca job talend
		    	BaseSearchInput filter = new BaseSearchInput();
		    	String flowDoId = table != null ? table.getFlowDO().getId() : "";
		    	String versionDoId = table != null ? table.getVersionDO().getId() : "";
		    	filter.setParam("flowId", flowDoId);
		    	filter.setParam("version", versionDoId);
		    	List<JobTalendDO> list = jobTalendDAO.cerca(filter, null);
		    	if(list != null && !list.isEmpty()) {
		    		JobTalendDO jobTalend = list.get(0);
		    		JobTalendFileDO jobFile = jobTalendFileDAO.findById(jobTalend.getId()).get();
		    		if(jobFile == null) {
		    			LOGGER.error("<<<<<<<<<<<<<<<<<<<<<<<<<< JOB ANNULLAMENTO PRATICA: JOB TALEND DI ANNULLAMENTO NON TROVATO PER: " + filter.getParam("flowId") + " , " + filter.getParam("version") + " >>>>>>>>>>>>>>>>>>>>>>>>>");
		    			return;
		    		}
		    		
		    		List<String> parameters = new ArrayList<String>();
		            
		            JobTalendDipendencyDO dep = new JobTalendDipendencyDO();
		            dep.setJobTalendFile(jobFile);
		            List<JobTalendDipendencyDO> listDep = jobTalendDependenciesDAO.findAll(Example.of(dep));
		            URL[] urls = new URL[listDep.size()+1];
		            if(listDep.size() > 0) {
		            	for(JobTalendDipendencyDO dipendenza: listDep) {
		                    try {
		    					File dependenceFile = File.createTempFile(dipendenza.getName(), ".jar");
		    					FileUtils.writeByteArrayToFile(dependenceFile, dipendenza.getJar());
		    					urls[listDep.indexOf(dipendenza)] = dependenceFile.toURI().toURL();
		    				} catch (IOException e) {
		    					e.printStackTrace();
		    				}

		            	}
		            }
		            
		            Method methodset = null;
		            Object instance = null;
		            URLClassLoader loader = null;
		            
		            try {
			            LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     JOB ANNULLAMENTO PRATICA: Talend jar trovato, path impostato correttamente -> Creazione Loader    >>>>>>>>>>>>>>>>>>>>>>>");
			
			            loader = WebappClassLoader.newInstance(urls, getClass().getClassLoader());
			            Class<?> clazz = loader.loadClass(jobTalend.getPackageJob() + "." + jobTalend.getClassName());
			            
			            LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     JOB ANNULLAMENTO PRATICA: Loader funzionante -> Ricerca metodo RunJob     >>>>>>>>>>>>>>>>>>>>>>>");
			
			            instance = clazz.newInstance();
			            methodset = clazz.getMethod("runJob", String[].class);
		            } catch (Exception ex) {
		            	LOGGER.error("<<<<<<<<<<<<<<<<<<<<<<<<  JOB ANNULLAMENTO PRATICA: ERRORE(1) >>>>>>>>>>>>>>>>>>>>>>>");
		            	ex.printStackTrace();
		            	return;
		            }

		            LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     JOB ANNULLAMENTO PRATICA: Metodo riconosciuto -> Impostazione parametri     >>>>>>>>>>>>>>>>>>>>>>>");

		            TalendDbDO talend = talendDbDAO.findById("1").get();

		            parameters.add("--context= ");
		            parameters.add("--context_param host=" + talend.getHost());
		            parameters.add("--context_param port=" + talend.getPort());
		            parameters.add("--context_param database=" + talend.getDatabase());
		            parameters.add("--context_param username=" + username);
		            parameters.add("--context_param password=" + password);
		            if(table!=null) {
		            	parameters.add("--context_param flowId=" + table.getFlowDO().getId());
		            }
		            parameters.add("--context_param urlJdbc=" + URL);
		            parameters.add("--context_param crypto=" + crypto);
		            parameters.add("--context_param pk=" + pk);


		            LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     JOB ANNULLAMENTO PRATICA: Parametri impostati -> Invocazione metodo RunJob    >>>>>>>>>>>>>>>>>>>>>>>");
		            
		            try {
			            int size = parameters != null ? parameters.size() : 0;
			            String[] args = null;
			            if (size > 0)
			                args = parameters.toArray(new String[]{});
			            Object[] argomenti = new Object[1];
			            argomenti[0] = args;
			            
						Object retObj = methodset.invoke(instance, argomenti);
						
						loader.close();
		            } catch (Exception ex) {
		            	LOGGER.error("<<<<<<<<<<<<<<<<<<<<<<<<  JOB ANNULLAMENTO PRATICA: ERRORE(2) >>>>>>>>>>>>>>>>>>>>>>>");
		            	ex.printStackTrace();
		            }
		    		
		    	}
		    	
		    	LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     JOB ANNULLAMENTO PRATICA: FINE    >>>>>>>>>>>>>>>>>>>>>>>");
			}
		};
		
		thread.start();
			
    }
    

    @Override
	public Boolean jobTalendJar (String exportId) {
		Boolean result = true;
        FlowExportRequestDO flowExportRequestDO = retriveOne(exportId);
        Set<FlowExportMessageDetailsDO> errorsDO = new HashSet<FlowExportMessageDetailsDO>();
        LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     Inizio processo invocazione Talend Jar     >>>>>>>>>>>>>>>>>>>>>>>");

//        JobTalendDTO jobTalend = flowExportRequestDO.getJobTalendId();
        
        flowExportRequestDO.setStartExtractionDate(new Date());
        try {

            LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     Ricerca jar nel path indicato     >>>>>>>>>>>>>>>>>>>>>>>");

            JobTalendFileDO jobFile = jobTalendFileDAO.findById(flowExportRequestDO.getJobTalendId().getId()).get();
            if (jobFile == null) {
                LOGGER.error("<<<<<<<<<<<<<<<<<<<<<<<<     Talend jar non trovato trovato (id = " + flowExportRequestDO.getJobTalendId().getId() + " >>>>>>>>>>>>>>>>>>>>>>>");
                result = false;
                try {
	                if (!result) {
	                	org.springframework.statemachine.state.State<String, String> stateExtraction = stateMachineFlow.execute(flowExportRequestDO.getId(), "EXPORT", MachineEvent.EXPORT_FAILED.getEvent());
						String state = stateExtraction.getId();
			            if (flowExportRequestDO.getStatus() != state) {
			            	
                            Integer records = talendThreadService.countExtractionRecord(flowExportRequestDO);
                            flowExportRequestDO.setRecord(records.toString());
			                flowExportRequestDO.setStatus(state);
			                flowExportRequestDO.setEndExtractionDate(new Date());
			            }
					} else {
                        Integer records = talendThreadService.countExtractionRecord(flowExportRequestDO);
                        flowExportRequestDO.setRecord(records.toString());
	                    flowExportRequestDO.setEndExtractionDate(new Date());
	                }
//					websocketServer.broadcastFlowExtractRequest("update");

				} catch (Exception e) {
					e.printStackTrace();
				}
				return false;
            }

            List<String> parameters = new ArrayList<String>();
            
            JobTalendDipendencyDO dep = new JobTalendDipendencyDO();
            dep.setJobTalendFile(jobFile);
            List<JobTalendDipendencyDO> listDep = jobTalendDependenciesDAO.findAll(Example.of(dep));
            URL[] urls = new URL[listDep.size()+1];
            if(listDep.size()>0) {
            	File[] files = new File[listDep.size()];
            	for(JobTalendDipendencyDO dependence: listDep) {
                    try {
    					File dependenceFile = File.createTempFile(dependence.getName(), ".jar");
    					FileUtils.writeByteArrayToFile(dependenceFile, dependence.getJar());
    					urls[listDep.indexOf(dependence)] = dependenceFile.toURI().toURL();
    					files[listDep.indexOf(dependence)] = dependenceFile;
    				} catch (IOException e) {
    					e.printStackTrace();
    				}

            	}
            }

            File file = File.createTempFile(flowExportRequestDO.getJobTalendId().getName(), ".jar");
            FileUtils.writeByteArrayToFile(file, jobFile.getJob());
			urls[listDep.size()] = file.toURI().toURL();

            LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     Talend jar trovato, path impostato correttamente -> Creazione Loader    >>>>>>>>>>>>>>>>>>>>>>>");

            URLClassLoader loader = WebappClassLoader.newInstance(urls, getClass().getClassLoader());
            Class<?> clazz = loader.loadClass(flowExportRequestDO.getJobTalendId().getPackageJob() + "." + flowExportRequestDO.getJobTalendId().getClassName());
            
            LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     Loader funzionante -> Ricerca metodo RunJob     >>>>>>>>>>>>>>>>>>>>>>>");

            Object instance = clazz.newInstance();
            Method methodset = clazz.getMethod("runJob", String[].class);

            LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     Metodo riconosciuto -> Impostazione parametri     >>>>>>>>>>>>>>>>>>>>>>>");

            TalendDbDO talend = talendDbDAO.findById("1").get(); //TODO gestione eccezioni se talend nullo
            
            //caricamento lista aziende visibili dall'utente
            List<String> aziende = flowManagerProfileService.getAziendeForUserProfile();
            
            parameters.add("--context= ");
            parameters.add("--context_param extractionId=" + flowExportRequestDO.getId());
            parameters.add("--context_param host=" + talend.getHost());
            parameters.add("--context_param port=" + talend.getPort());
            parameters.add("--context_param database=" + talend.getDatabase());
            parameters.add("--context_param username=" + username);
            parameters.add("--context_param password=" + password);
            parameters.add("--context_param flowId=" + flowExportRequestDO.getFlow().getId());
            parameters.add("--context_param urlJdbc=" + URL);
            parameters.add("--context_param crypto=" + crypto);
            if (!aziende.isEmpty()) {
            	parameters.add("--context_param aziendeprofilate=" + "'" + String.join("','",aziende) + "'");
			}
            
            LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     Parametri impostati -> Invocazione metodo RunJob    >>>>>>>>>>>>>>>>>>>>>>>");
            
            int size = parameters != null ? parameters.size() : 0;
            String[] args = null;
            if (size > 0)
                args = parameters.toArray(new String[]{});
            Object[] argomenti = new Object[1];
            argomenti[0] = args;
            
            threadMap.put(exportId, true);
            
            try {
    			Thread thread = new Thread() {
				@Transactional
				public void run() {
					
                    try {
						Object retObj = methodset.invoke(instance, argomenti);
						
						boolean err = false;
						
						if(threadMap.containsKey(exportId)) {
				    		boolean result = threadMap.get(exportId);
				    		if(result == false) {
				    			retObj = null;		
				    			FlowExportMessageDetailsDO error = new FlowExportMessageDetailsDO();
								error.setErrorValue("Estrazione terminata dall'utente");
								error.setFlowExportRequest(flowExportRequestDO);
								errorsDO.add(error);
					    		err = true;
				    		}
				    		
				    		threadMap.remove(exportId);
				    	}
												
						if (retObj != null && retObj instanceof String[][]) {
							for (String[] strings : (String[][]) retObj) {
								String esito = "0";
								
								if(strings.length > 2) {
									esito = strings[2];
								} else if(strings.length > 0) {
									esito = strings[0];
								}
								
								if(Integer.valueOf(esito) < 0) { //CONTROLLARE CHE NELLA POSIZIONE 2 CI SIA SEMPRE IL CODICE DELL'ERRORE E CHE SIA -1 E CHE NELLA POSIZIONE 0 CI SIA LA DESCRIZIONE
									FlowExportMessageDetailsDO error = new FlowExportMessageDetailsDO();
									error.setErrorValue(strings[0]);
									error.setFlowExportRequest(flowExportRequestDO);
									errorsDO.add(error);
									err = true;
								}
							}
						}
						
						if(!errorsDO.isEmpty()) {
							flowExportRequestDO.setFlowExportMessageDetails(errorsDO);
						}
						
			            loader.close();

                        LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     Metodo invocato correttamente, loader chiuso -> Invocazione StateMachine    >>>>>>>>>>>>>>>>>>>>>>>");

                        String state = "";
                        if(err) {
                        	org.springframework.statemachine.state.State<String, String> stateExtraction = stateMachineFlow.execute(flowExportRequestDO.getId(), "EXPORT", MachineEvent.EXPORT_FAILED.getEvent());
                        	state = stateExtraction.getId();
                        }else {
                        	org.springframework.statemachine.state.State<String, String> stateExtraction = stateMachineFlow.execute(flowExportRequestDO.getId(), "EXPORT", MachineEvent.EXPORT_SUCCESS.getEvent());
                        	state = stateExtraction.getId();
                        }
//        				websocketServer.broadcastFlowExtractRequest("update");
                        LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     StateMachine eseguita correttamente. FINE.     >>>>>>>>>>>>>>>>>>>>>>>");


                        if (!flowExportRequestDO.getStatus().equals(state)) {

                            flowExportRequestDO.setStatus(state);
			                Date date = new Date();
			                Integer records = 0;
			                if(!err) {
			                	records = talendThreadService.countExtractionRecord(flowExportRequestDO);
			                	int check = talendThreadService.checkValidation(flowExportRequestDO);
	                            if(check == 1) {
	                            	flowExportRequestDO.setValidationStatus("NOT_VALID");
	                            }else {
	                            	if(records > 0) {
	                            		flowExportRequestDO.setValidationStatus("XSD_VALIDATED");
	                            	}else {
	                            		flowExportRequestDO.setValidationStatus("NO_ROWS");
	                            	}
	                            }
			                }
                            flowExportRequestDO.setRecord(records.toString());
                            flowExportRequestDO.setEndExtractionDate(date);
                            
                            talendThreadService.save(flowExportRequestDO);
			            } else {
			                // PASSAGGIO DI STATO NON PERMESSO
			            }

                    } catch (Exception ex) {
						ex.printStackTrace();
						try {
							loader.close();
							LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     Loader chiuso     >>>>>>>>>>>>>>>>>>>>>>>");
                                //FlowExportRequestDO flowExportRequestDO = flowExportDAO.findOne(flowExportDTO.getId());
		                	org.springframework.statemachine.state.State<String, String> stateExtraction = stateMachineFlow.execute(flowExportRequestDO.getId(), "EXPORT", MachineEvent.EXPORT_FAILED.getEvent());
							String state = stateExtraction.getId();
                                if (flowExportRequestDO.getStatus() != state) {
				                flowExportRequestDO.setStatus(state);
//                                Integer records = talendThreadService.countExtractionRecord(flowExportDTO);
                                flowExportRequestDO.setRecord("");
				                flowExportRequestDO.setEndExtractionDate(new Date());
				                FlowExportMessageDetailsDO error = new FlowExportMessageDetailsDO();
								error.setErrorValue("Errore durante l'esecuzione del jar");
								error.setFlowExportRequest(flowExportRequestDO);
								errorsDO.add(error);
								flowExportRequestDO.setFlowExportMessageDetails(errorsDO);
				                talendThreadService.save(flowExportRequestDO);
				            }
						} catch (Exception e) {
							e.printStackTrace();
						}
			        } finally {
			        	threadMap.remove(exportId);
			        }
				}

                };
                
    			thread.start();
    			
				Thread thread2 = new Thread() {
					public void run() {
						try {
							while(threadMap.containsKey(exportId) && threadMap.get(exportId)) {
								Thread.sleep(10000);
							}
							
							if(thread.isAlive()) {
								Method destroy = clazz.getMethod("destroy");
								destroy.invoke(instance);
								talendThreadService.deleteErrors(exportId);
							}
							
						} catch (Exception e) {
							e.printStackTrace();
						} 
//						finally {
//							threadMap.remove(exportId);
//						}
					}
				};
				
				thread2.start();
				
    			return true;

    		} catch (Exception e) {
    			try {
    				loader.close();
                    //FlowExportRequestDO flowExportRequestDO = flowExportDAO.findOne(flowExportDTO.getId());
                	org.springframework.statemachine.state.State<String, String> stateExtraction = stateMachineFlow.execute(flowExportRequestDO.getId(), "EXPORT", MachineEvent.EXPORT_FAILED.getEvent());
					String state = stateExtraction.getId();
                    if (flowExportRequestDO.getStatus() != state) {
		                flowExportRequestDO.setStatus(state);
//                        Integer records = talendThreadService.countExtractionRecord(flowExportDTO);
                        flowExportRequestDO.setRecord("");
		                flowExportRequestDO.setEndExtractionDate(new Date());
		                FlowExportMessageDetailsDO error = new FlowExportMessageDetailsDO();
						error.setErrorValue("Errore durante l'esecuzione del jar");
						error.setFlowExportRequest(flowExportRequestDO);
						errorsDO.add(error);
						flowExportRequestDO.setFlowExportMessageDetails(errorsDO);
		                talendThreadService.save(flowExportRequestDO);
		            }
				} catch (Exception ex) {
					ex.printStackTrace();
				}
    			return false;
    		}
        }catch(Exception e) {
        	try {
                //FlowExportRequestDO flowExportRequestDO = flowExportDAO.findOne(flowExportDTO.getId());
            	org.springframework.statemachine.state.State<String, String> stateExtraction = stateMachineFlow.execute(flowExportRequestDO.getId(), "EXPORT", MachineEvent.EXPORT_FAILED.getEvent());
				String state = stateExtraction.getId();
                if (flowExportRequestDO.getStatus() != state) {
	                flowExportRequestDO.setStatus(state);
//                    Integer records = talendThreadService.countExtractionRecord(flowExportDTO);
                    flowExportRequestDO.setRecord("");
	                flowExportRequestDO.setEndExtractionDate(new Date());
	                FlowExportMessageDetailsDO error = new FlowExportMessageDetailsDO();
					error.setErrorValue("Errore durante l'esecuzione del jar");
					error.setFlowExportRequest(flowExportRequestDO);
					errorsDO.add(error);
					flowExportRequestDO.setFlowExportMessageDetails(errorsDO);
	                talendThreadService.save(flowExportRequestDO);
	            }
			} catch (Exception ex) {
				ex.printStackTrace();
			}
        	return false;
        }
    }
    
    @Override
	public boolean killJob (String exportId) {
    	
    	if(threadMap.containsKey(exportId)) {
    		putInMap(exportId);
    		return true;
    	}else {
    		return false;
    	}
    	
    }
    
    public synchronized void putInMap(String exportId) {
    	threadMap.put(exportId, false);
    }

    @Override
    public HashMap<String, Object> getFieldsByFlowAndVersion(String version, String flow) {

        HashMap<String, Object> hashMap = flowExportDAOQuery.searchFields(version, flow);

        return hashMap;
    }

    @Override
    public State<String, String> executeStateMachine(String id, String factoryModel, String event) throws Exception {
    	return stateMachineFlow.execute(id, "EXPORT", machineEvent.ESEGUI_EXPORT.getEvent());
    }

    @Override
    public List<Object[]> checkExtractObsoleta(FlowExportRequestDTO  flowExportDTO) throws SQLException {
        String version = flowExportDTO.getVersion().getId();
        String flow = flowExportDTO.getFlow().getId();
        //Recupero UNIONE FLUSSI
        FormFlowDTO formFlowDTOazi = formFlowService.retrieveOne(flow, version);
        //Recuper FLUSSO_AZIENDALE NON FUNZIONA
        //FormFlowDTO formFlowDTOreg = formFlowService.retrieveOne(flowRegioUnioDO.getFlowRegion().getId(), version);

        //Recupero chiavi Sezione 0
        List<String> pkList = new ArrayList<>();
        for (FormFlowTableFieldDTO formFlowTableFieldDTO : formFlowDTOazi.getFlowTableList().get(0).getFlowTableFieldList()) {
            if (formFlowTableFieldDTO.isPk()) {
                pkList.add(formFlowTableFieldDTO.getName());
            }
        }
        //Creao la SELECT DATE_PROCESSING + pkList
        String campiSelect = "EXTRACTION_ID, DATE_PROCESSING, ";
        for (String pKey : pkList) {
            campiSelect += pKey + ", ";
        }
        if (campiSelect.endsWith(", ")) {
            campiSelect = campiSelect.substring(0, campiSelect.length() - 2);
        }
        //Creao la WHERE DATE_PROCESSING + pkList
        String campiWhere = "FREG.DATE_PROCESSING < F.DATE_PROCESSING AND ";
        for (String pKey : pkList) {
            campiWhere += " FREG." + pKey + " = F." + pKey + " AND ";
        }
        if (campiWhere.endsWith("AND ")) {
            campiWhere = campiWhere.substring(0, campiWhere.length() - 4);
        }
        String selectSQL = "SELECT " + campiSelect +
                " FROM FM_FLOW_" + formFlowDTOazi.getName() + "_REG_" + formFlowDTOazi.getFlowTableList().get(0).getSection() + " FREG " +
                " WHERE EXTRACTION_ID=? AND EXISTS (" +
                " SELECT 1 FROM FM_FLOW_" + formFlowDTOazi.getName() + "_" + formFlowDTOazi.getFlowTableList().get(0).getSection() + " F WHERE " +
                campiWhere + ")";

        LOGGER.debug("SELECT SQL QUERY:" + selectSQL);
        //Lista Object Pratiche errate
        List<Object[]> checkList = new ArrayList<>();

//        SessionImpl session = (SessionImpl) entityManager.getDelegate();
        Connection connectionLocal = dataSource.getConnection();
        try {
            connectionLocal.setAutoCommit(false);
            PreparedStatement preparedStatement =
                    connectionLocal.prepareStatement(selectSQL,
                            ResultSet.TYPE_FORWARD_ONLY,
                            ResultSet.CONCUR_UPDATABLE,
                            ResultSet.FETCH_FORWARD);
            preparedStatement.setFetchSize(5000);
            preparedStatement.setString(1, flowExportDTO.getId());
            ResultSet resultSet = preparedStatement.executeQuery();
            while (resultSet.next()) {
                Object[] objects = new Object[pkList.size()];
                int i = 0;
                for (String pKey : pkList) {
                    objects[i] = resultSet.getString(pKey.toUpperCase());
                    i++;
                }
                checkList.add(objects);
            }
        } catch (SQLException e) {
            e.printStackTrace();
        }
        //TEST CONSOLIDA PRATICHE
        //consolidaPratiche(flowExportDTO);
        return checkList;
    }

    public Integer consolidaPratiche(FlowExportRequestDTO flowExportDTO, String status) {
        //Integer numRecCons = 0;

        String version = flowExportDTO.getVersion().getId();
        String flow = flowExportDTO.getFlow().getId();
        //Recupero UNIONE FLUSSI
        //Recupero FLUSSO_REGIONALE
        FormFlowDTO formFlowDTOazi = formFlowService.retrieveOne(flow, version);
        //Recuper FLUSSO_AZIENDALE
        //FormFlowDTO formFlowDTOreg = formFlowService.retrieveOne(flowRegioUnioDO.getFlowRegion().getId(), version);
        //MODIFICA CAMPO REGIONALI

        //Recupero chiavi Sezione 0
        List<String> pkList = new ArrayList<>();
        for (FormFlowTableFieldDTO formFlowTableFieldDTO : formFlowDTOazi.getFlowTableList().get(0).getFlowTableFieldList()) {
            if (formFlowTableFieldDTO.isPk()) {
                pkList.add(formFlowTableFieldDTO.getName());
            }
        }

        //FLAG PER VALIDAZIONE
        Boolean joinScartoRegionale = status.equals(StateSendRegionEnum.ACCETTATA.name());
        
        //Costruzione SQL SELECT REGIONALE
        String SQL_SELECT_R = generateQuerySelect(pkList, formFlowDTOazi.getName(), formFlowDTOazi.getFlowTableList().get(0).getSection(), joinScartoRegionale);
        
        //Contruzione SQL UPDATE REGIONALE
        String SQL_UPDATE_R = "UPDATE FM_FLOW_" + formFlowDTOazi.getName() +
                "_REG_" + formFlowDTOazi.getFlowTableList().get(0).getSection() +
                " SET STATE_SEND_REGION = '" + status + "' " + (joinScartoRegionale ? " , STATUS_REGION = ?" : "");
        String where = " WHERE EXTRACTION_ID = ? AND ";
        
        for (String pKey : pkList) {
            where += pKey + "=" + "? AND ";
        }
        if (where.endsWith("AND ")) { 
            where = where.substring(0, where.length() - 4);
        }
        SQL_UPDATE_R += where;
        LOGGER.info("SQL_UPDATE_R : " + SQL_UPDATE_R);
        LOGGER.info("TABELLA SQL_UPDATE_R : " +  "FM_FLOW_" + formFlowDTOazi.getName() + "_REG_" + formFlowDTOazi.getFlowTableList().get(0).getSection());
        
        //Contruzione SQL UPDATE AZIENDALE
        String SQL_UPDATE_A = "UPDATE FM_FLOW_" + formFlowDTOazi.getName() +
                "_" + formFlowDTOazi.getFlowTableList().get(0).getSection() +
                " SET STATE_SEND_REGION = '" + status + "'" + (joinScartoRegionale ? " , STATUS_REGION = ?" : "");
        String where2 = " WHERE ";
        for (String pKey : pkList) {
            where2 += pKey + "=" + "? AND ";
        }
        if (where2.endsWith("AND ")) {
            where2 = where2.substring(0, where2.length() - 4);
        }
        SQL_UPDATE_A += where2;
        LOGGER.info("SQL_UPDATE_A : " + SQL_UPDATE_A);
        LOGGER.info("TABELLA SQL_UPDATE_R : " +  "FM_FLOW_" + formFlowDTOazi.getName() + "_" + formFlowDTOazi.getFlowTableList().get(0).getSection());
        //OPEN SESSIONE
        int count = 0;
        try {
            SessionImpl session = (SessionImpl) entityManager.getDelegate();
            Connection conn = dataSource.getConnection();
            conn.setAutoCommit(false);
            PreparedStatement preparedStatementSelect = conn.prepareStatement(SQL_SELECT_R);
            preparedStatementSelect.setFetchSize(5000);
            preparedStatementSelect.setString(1, flowExportDTO.getId());
            ResultSet resultSet = preparedStatementSelect.executeQuery();
            PreparedStatement preparedStatementUpdateRegionale = conn.prepareStatement(SQL_UPDATE_R);
            preparedStatementUpdateRegionale.setFetchSize(5000);
            PreparedStatement preparedStatementUpdateAziendale = conn.prepareStatement(SQL_UPDATE_A);
            preparedStatementUpdateAziendale.setFetchSize(5000);
            
            Boolean next = false;
            Boolean execute = false;
            do {
            	next = resultSet.next();
            	
            	if(next) {
            		execute = true;
            		
	            	Integer offsetParam = 0;
	            	String severityScarto = "";
	            	if(joinScartoRegionale) {
	            		offsetParam = 1;
	            		severityScarto = resultSet.getString("SEVERITY_SCARTO_REG");
	            		if(severityScarto == null || severityScarto.isEmpty()) {
	            			severityScarto = "VALIDO";
	            		}
	            		preparedStatementUpdateRegionale.setString(1, severityScarto);
	            		preparedStatementUpdateAziendale.setString(1, severityScarto);
	            	}
	            	
	                //REGIONALE + AZIENDALE
	                preparedStatementUpdateRegionale.setString(1 + offsetParam, resultSet.getString("EXTRACTION_ID"));
	                int indexParam = 2 + offsetParam;
	                for (String pKey : pkList) {
	                    preparedStatementUpdateRegionale.setString(indexParam, resultSet.getString(pKey.toUpperCase()));
	                    preparedStatementUpdateAziendale.setString(indexParam - 1, resultSet.getString(pKey.toUpperCase()));
	                    indexParam++;
	                }
	                preparedStatementUpdateRegionale.addBatch();
	                preparedStatementUpdateAziendale.addBatch();
            	}
            	
                if (count > 0 && count % 1000 == 0 || !next) {
                	if(execute) {
	                    preparedStatementUpdateAziendale.executeBatch();
	                    preparedStatementUpdateRegionale.executeBatch();
	                    conn.commit();
	                    preparedStatementUpdateAziendale.clearBatch();
	                    preparedStatementUpdateRegionale.clearBatch();
	                    preparedStatementUpdateAziendale.clearParameters();
	                    preparedStatementUpdateRegionale.clearParameters();
                	}
                }
                count++;
                
            } while (next);
            
        } catch (SQLException e) {
            e.printStackTrace();
            return -1;
        }

            return count;
        }
    
    
    @Override
    public Integer consolidaRitorni(FormFlowDTO configurationRegion, FlowExportRequestDTO flowExportDTO, String status, Boolean joinScartoRegionale, TabgenMap tracciatoSegnalazioniRegionali) {
    	boolean checkExt = false;
    	String SQL_UPDATE_EXT = "";
    	String tableExt = "";
    	ConfigurationDO cfgObj = configuration.findByKeyId("flowWithExternalUpdate");
    	if(cfgObj!=null) {
    		String cfg = cfgObj.getValue();
    		String[] cfgSplitted = cfg.split("/");
        	for (int i = 0; i < cfgSplitted.length; i++) {
    			String value = cfgSplitted[i];
    			int iend = value.indexOf("(");
    			String flusso = value.substring(0,iend);
    			String flussoCopia = value.substring(iend+1,value.length()-1);
    			if(flusso!=null && !"".equals(flusso) && flusso.equals(flowExportDTO.getFlow().getName())){
    				checkExt = true;
    				tableExt = "FM_FLOW_" + flussoCopia + "_0";
    			}
        	}
    	}
    	
    	String version = flowExportDTO.getVersion().getId();
        String flow = flowExportDTO.getFlow().getId();
        FormFlowDTO formFlowDTOaziendale = formFlowService.retrieveOne(flow, version);
        
        // Recupero chiavi aziendali Sezione 0
        List<String> azPkList = new ArrayList<>();
        for (FormFlowTableFieldDTO formFlowTableFieldDTO : formFlowDTOaziendale.getFlowTableList().get(0).getFlowTableFieldList()) {
            if (formFlowTableFieldDTO.isPk()) {
                azPkList.add(formFlowTableFieldDTO.getName());
            }
        }
        
        // Recupero chiavi regionali sezione 0
        List<String> regPkList = new ArrayList<>();
        for (FormFlowTableFieldDTO formFlowTableFieldDTO : configurationRegion.getFlowTableList().get(0).getFlowTableFieldList()) {
            if (formFlowTableFieldDTO.isPk()) {
           		regPkList.add(formFlowTableFieldDTO.getName());
            }
        }
        
        List<String> joinFieldsWithRegionReturns = new ArrayList<String>();
        if(joinScartoRegionale) {
	        for(TabgenValueMap joinField : tracciatoSegnalazioniRegionali.getTabgenValueList()) {
	        	if(null != joinField.getIsPk() && joinField.getIsPk()) {
	        		joinFieldsWithRegionReturns.add(joinField.getFieldName());
	        	}
	        }
        }
        
        // seleziona sia le pk aziendali che le pk regionali
        Set<String> selectRegList = new HashSet<String>(azPkList);
        selectRegList.addAll(regPkList);

        //Costruzione SQL SELECT REGIONALE
        String SQL_SELECT_R = generateQuerySelectRitorni(new ArrayList<String>(selectRegList), joinFieldsWithRegionReturns, formFlowDTOaziendale.getName(), formFlowDTOaziendale.getFlowTableList().get(0).getSection(), joinScartoRegionale);
        LOGGER.info("SQL_SELECT_R : " + SQL_SELECT_R);
        //NUOVO SVILUPPO
        //LA SELECT REGIONALE DEVE FORNIRMI ANCHE L'INFORMAZIONE DELLA PROVENIENZA DELLA PRATICA ESTRATTA COSI DA SAPERE SE L'UPDATE VERTICALE VA FATTO
        //SULLA VERTICALE INTERNA O ESTERNA
        if(checkExt) {
        	String SQL_NEW_SELECT = "SELECT t1.FLAG_ESTERNO FLAG_ESTERNO,";
            SQL_SELECT_R = SQL_SELECT_R.substring(6);
            SQL_SELECT_R = SQL_NEW_SELECT + SQL_SELECT_R;

            //PREPARO LA UPDATE PER LA TABELLA ESTERNA
            SQL_UPDATE_EXT = "UPDATE " + tableExt +
                    " SET STATE_SEND_REGION = '" + status + "'" + (joinScartoRegionale ? " , STATUS_REGION = ?" : "");
            String where3 = " WHERE ";
            for (String pKey : azPkList) {
                where3 += pKey + "=" + "? AND ";
            }
            if (where3.endsWith("AND ")) {
                where3 = where3.substring(0, where3.length() - 4);
            }
            SQL_UPDATE_EXT += where3;
            LOGGER.info("SQL_UPDATE_EXT : " + SQL_UPDATE_EXT);
        }
        
        
        //Contruzione SQL UPDATE REGIONALE
        String SQL_UPDATE_R = "UPDATE FM_FLOW_" + configurationRegion.getName() + "_{SECTION}" +
                " SET STATE_SEND_REGION = '" + status + "' " + (joinScartoRegionale ? " , STATUS_REGION = ?" : "");
        String where = " WHERE EXTRACTION_ID = ? AND ";
        for (String pKey : regPkList) {
            where += pKey + "=" + "? AND ";
        }
        if (where.endsWith("AND ")) {
            where = where.substring(0, where.length() - 4);
        }
        SQL_UPDATE_R += where;
        LOGGER.info("SQL_UPDATE_R : " + SQL_UPDATE_R);
        
        //Contruzione SQL UPDATE AZIENDALE
        String SQL_UPDATE_A = "UPDATE FM_FLOW_" + formFlowDTOaziendale.getName() + "_{SECTION}" +
                " SET STATE_SEND_REGION = '" + status + "'" + (joinScartoRegionale ? " , STATUS_REGION = ?" : "");
        String where2 = " WHERE ";
        for (String pKey : azPkList) {
            where2 += pKey + "=" + "? AND ";
        }
        if (where2.endsWith("AND ")) {
            where2 = where2.substring(0, where2.length() - 4);
        }
        SQL_UPDATE_A += where2;
        LOGGER.info("SQL_UPDATE_A : " + SQL_UPDATE_A);
        
        int count = 0;
        String regionValidationStatus = "VALIDO";
        try {
            Connection conn = dataSource.getConnection();
            conn.setAutoCommit(false);
            PreparedStatement preparedStatementSelect = conn.prepareStatement(SQL_SELECT_R);
            preparedStatementSelect.setFetchSize(5000);
            preparedStatementSelect.setString(1, flowExportDTO.getId());
            LOGGER.info("SQL_SELECT_R - PAR1 : " + flowExportDTO.getId());
            ResultSet resultSet = preparedStatementSelect.executeQuery();
            
            List<PreparedStatement> preparedStatementUpdateRegionaleList = new ArrayList<PreparedStatement>();
            List<PreparedStatement> preparedStatementUpdateAziendaleList = new ArrayList<PreparedStatement>();
            PreparedStatement preparedStatementUpdateAziendaleExt = null;
            PreparedStatement preparedStatementUpdateRegionale = null;
    		PreparedStatement preparedStatementUpdateAziendale = null;
    		
    		if (null != flowExportDTO.getConsolidata() && flowExportDTO.getConsolidata()) {
	            for(FormFlowTableDTO table : formFlowDTOaziendale.getFlowTableList()) {
	            	String SQL_UPDATE_A_sec = SQL_UPDATE_A.replace("{SECTION}", table.getSection() + "");
		            preparedStatementUpdateAziendale = conn.prepareStatement(SQL_UPDATE_A_sec);
		            LOGGER.info("SQL_UPDATE_A_SEC : " + SQL_UPDATE_A_sec);
		            preparedStatementUpdateAziendale.setFetchSize(5000);
		            preparedStatementUpdateAziendaleList.add(preparedStatementUpdateAziendale);
	            }
	            
	            for(FormFlowTableDTO table : configurationRegion.getFlowTableList()) {
	            	String SQL_UPDATE_R_sec = SQL_UPDATE_R.replace("{SECTION}", table.getSection() + "");
	            	preparedStatementUpdateRegionale = conn.prepareStatement(SQL_UPDATE_R_sec);
	            	LOGGER.info("SQL_UPDATE_R_sec : " + SQL_UPDATE_R_sec);
	            	preparedStatementUpdateRegionale.setFetchSize(5000);
	            	preparedStatementUpdateRegionaleList.add(preparedStatementUpdateRegionale);
	            }
	            
	            if(!"".equals(SQL_UPDATE_EXT)) {
	            	preparedStatementUpdateAziendaleExt = conn.prepareStatement(SQL_UPDATE_EXT);
	            	preparedStatementUpdateAziendaleExt.setFetchSize(5000);
	            }
    		}
    		
            Boolean next = false;
            Boolean execute = false;
            do {
            	next = resultSet.next();
            	
            	int w1 = 0;
            	String severityScarto = "";
            	
            	if(next && joinScartoRegionale) {
	            	severityScarto = resultSet.getString("SEVERITY_SCARTO_REG");
	            	if(severityScarto == null || severityScarto.isEmpty()) {
	        			severityScarto = "VALIDO";
	        		}
	            	w1 = severityScarto.equals("VALIDO") ? 0 : severityScarto.equals("SEGNALAZIONE") ? 1 : 2;
            	}
            	
            	int w2 = regionValidationStatus.equals("VALIDO") ? 0 : regionValidationStatus.equals("SEGNALAZIONE") ? 1 : 2;
        		
        		if(w1 >= w2) {
        			regionValidationStatus = severityScarto;
        		}
        		
        		if (null != flowExportDTO.getConsolidata() && flowExportDTO.getConsolidata()) {
	            	for(int i = 0; i < preparedStatementUpdateRegionaleList.size(); i++) {
	            		
	            		preparedStatementUpdateRegionale = preparedStatementUpdateRegionaleList.get(i);
	            	
		            	if(next) {
		            		execute = true;
		            		
		            		int indexParam = 1;
			            	if(joinScartoRegionale) {
			            		preparedStatementUpdateRegionale.setString(indexParam, severityScarto);
			            		LOGGER.info("preparedStatementUpdateRegionale - joinScartoRegionale - PAR"+indexParam+" : " + severityScarto);
			            		indexParam++;
			            	}
			            	
			                preparedStatementUpdateRegionale.setString(indexParam, resultSet.getString("EXTRACTION_ID"));
			                LOGGER.info("preparedStatementUpdateRegionale - PAR"+indexParam+" : " + resultSet.getString("EXTRACTION_ID"));
			                indexParam++;
			                
			                for (String pKey : regPkList) {
			                    preparedStatementUpdateRegionale.setString(indexParam, resultSet.getString(pKey.toUpperCase()));
			                    LOGGER.info("preparedStatementUpdateRegionale - PAR"+indexParam+" : " + resultSet.getString(pKey.toUpperCase()));
			                    indexParam++;
			                }
			                
			                preparedStatementUpdateRegionale.addBatch();
		            	}
		            	
		                if (count > 0 && count % 1000 == 0 || !next) {
		                	if(execute) {
			                    preparedStatementUpdateRegionale.executeBatch();
			                    conn.commit();
			                    preparedStatementUpdateRegionale.clearBatch();
			                    preparedStatementUpdateRegionale.clearParameters();
		                	}
		                }
		                
	            	}
	            	
	            	//NUOVO SVILUPPO
	            	//SE NON è CONFIGURATO, PROCEDI COSI PER LA VERTICALE
	            	if(!checkExt) {
	            		for(int i = 0; i < preparedStatementUpdateAziendaleList.size(); i++) {
	                		
	                		preparedStatementUpdateAziendale = preparedStatementUpdateAziendaleList.get(i);
	                	
	    	            	if(next) {
	    	            		execute = true;
	    	            		
	    		            	int indexParam = 1;
	    		            	if(joinScartoRegionale) {
	    		            		preparedStatementUpdateAziendale.setString(indexParam, severityScarto);
	    		            		LOGGER.info("preparedStatementUpdateAziendale - joinScartoRegionale - PAR"+indexParam+" : " + severityScarto);
	    		            		indexParam++;
	    		            	}
	    		            	
	    		                for (String pKey : azPkList) {
	    		                    preparedStatementUpdateAziendale.setString(indexParam, resultSet.getString(pKey.toUpperCase()));
	    		                    LOGGER.info("preparedStatementUpdateAziendale - PAR"+indexParam+" : " + resultSet.getString(pKey.toUpperCase()));
	    		                    indexParam++;
	    		                }
	    		                
	    		                preparedStatementUpdateAziendale.addBatch();
	    	            	}
	    	            	
	    	                if (count > 0 && count % 1000 == 0 || !next) {
	    	                	if(execute) {
	    		                    preparedStatementUpdateAziendale.executeBatch();
	    		                    conn.commit();
	    		                    preparedStatementUpdateAziendale.clearBatch();
	    		                    preparedStatementUpdateAziendale.clearParameters();
	    	                	}
	    	                }
	    	                
	                	}
	            	}else {
	                    //NUOVO SVILUPPO
	                	//ALTRIMETI SE è CONFIGURATO CONTROLLO DALLA TABELLA REG LA PROVENIENZA DELLA PRATICA E DECIDO DI CONSEGUENZA DOVE LANCIARE L'UPDATE
	            		String flag_esterno = null;
	            		if(next) {
	            			flag_esterno = resultSet.getString("FLAG_ESTERNO");
	            		}
	                	if(flag_esterno!=null && !"".equals(flag_esterno)) {
	                		flag_esterno = null;
	                		if(next) {
	    	            		execute = true;
	    		            	int indexParam = 1;
	    		            	if(joinScartoRegionale) {
	    		            		preparedStatementUpdateAziendaleExt.setString(indexParam, severityScarto);
	    		            		LOGGER.info("preparedStatementUpdateAziendaleExt - joinScartoRegionale - PAR"+indexParam+" : " + severityScarto);
	    		            		indexParam++;
	    		            	}
	    		                for (String pKey : azPkList) {
	    		                	preparedStatementUpdateAziendaleExt.setString(indexParam, resultSet.getString(pKey.toUpperCase()));
	    		                	LOGGER.info("preparedStatementUpdateAziendaleExt - PAR"+indexParam+" : " + resultSet.getString(pKey.toUpperCase()));
	    		                    indexParam++;
	    		                }
	    		                preparedStatementUpdateAziendaleExt.addBatch();
	    	            	}
	    	                if (count > 0 && count % 1000 == 0 || !next) {
	    	                	if(execute) {
	    	                		preparedStatementUpdateAziendaleExt.executeBatch();
	    		                    conn.commit();
	    		                    preparedStatementUpdateAziendaleExt.clearBatch();
	    		                    preparedStatementUpdateAziendaleExt.clearParameters();
	    	                	}
	    	                }
	                	}else {
	                		for(int i = 0; i < preparedStatementUpdateAziendaleList.size(); i++) {
	                    		preparedStatementUpdateAziendale = preparedStatementUpdateAziendaleList.get(i);
	        	            	if(next) {
	        	            		execute = true;
	        		            	int indexParam = 1;
	        		            	if(joinScartoRegionale) {
	        		            		preparedStatementUpdateAziendale.setString(indexParam, severityScarto);
	        		            		LOGGER.info("preparedStatementUpdateAziendale - joinScartoRegionale - PAR"+indexParam+" : " + severityScarto);
	        		            		indexParam++;
	        		            	}
	        		                for (String pKey : azPkList) {
	        		                    preparedStatementUpdateAziendale.setString(indexParam, resultSet.getString(pKey.toUpperCase()));
	        		                    LOGGER.info("preparedStatementUpdateAziendale - PAR"+indexParam+" : " + resultSet.getString(pKey.toUpperCase()));
	        		                    indexParam++;
	        		                }
	        		                preparedStatementUpdateAziendale.addBatch();
	        	            	}
	        	                if (count > 0 && count % 1000 == 0 || !next) {
	        	                	if(execute) {
	        		                    preparedStatementUpdateAziendale.executeBatch();
	        		                    conn.commit();
	        		                    preparedStatementUpdateAziendale.clearBatch();
	        		                    preparedStatementUpdateAziendale.clearParameters();
	        	                	}
	        	                }
	                    	}
	                	}
	                	
	            	}
	            	count++;
        		}
	                
	            } while (next);
            
            if (null != flowExportDTO.getConsolidata() && flowExportDTO.getConsolidata()) {
	            for(int i = 0; i < preparedStatementUpdateAziendaleList.size(); i++) {
	        		preparedStatementUpdateAziendale = preparedStatementUpdateAziendaleList.get(i);
	                preparedStatementUpdateAziendale.executeBatch();
	                conn.commit();
	                preparedStatementUpdateAziendale.clearBatch();
	                preparedStatementUpdateAziendale.clearParameters();
	
	            }
	            if(preparedStatementUpdateAziendaleExt!=null) {
	            	preparedStatementUpdateAziendaleExt.executeBatch();
	                conn.commit();
	                preparedStatementUpdateAziendaleExt.clearBatch();
	                preparedStatementUpdateAziendaleExt.clearParameters();
	            }
            }
            
            FlowExportRequestDO request = flowExportDAO.getOne(flowExportDTO.getId());
            request.setRegionValidationStatus(regionValidationStatus);
            
            
        } catch (SQLException e) {
            e.printStackTrace();
            return -1;
        }

        return count;
        
    }
    
    

    @Override
    public FlowExportRequestDO retriveOne(String id) {
        return flowExportDAO.findById(id).get();
    }

    @Override
    public Boolean logicDelete(List<FlowExportRequestDO> flowExportRequestDOS) {
        try {
            for (FlowExportRequestDO flowExportRequestDO : flowExportRequestDOS) {
                flowExportRequestDO.setDeleted(1);
                flowExportDAO.save(flowExportRequestDO);
            }
            return true;
        } catch (Exception e) {
            LOGGER.error("ERROR (logical) DELETE FLOW EXPORT ROW: " + e.getMessage());
            return false;
        }
    }

    @Override
    public Boolean delete() {
        try {
        	//caricamento lista aziende visibili dall'utente
    		List<String> aziende = flowManagerProfileService.getAziendeForUserProfile();
    		
            BaseSearchInput baseSearchInput = new BaseSearchInput();
            baseSearchInput.setValue("deleted", 1);
            baseSearchInput.setParam("aziende", aziende);
            Pair<List<FlowExportRequestDO>, SearchInfo> list = retrieveAllFiltered(baseSearchInput, false);
            for (FlowExportRequestDO flowExportRequestDO : list.getFirst()) {
                //DELETE REGION TABLE
                formFlowService.deletebyExtractionId(flowExportRequestDO.getId(),
                        flowExportRequestDO.getFlow(),
                        flowExportRequestDO.getVersion());
                flowExportDAO.deleteById(flowExportRequestDO.getId());
            }
            return true;
        } catch (Exception e) {
            LOGGER.error("ERROR (physical) DELETE FLOW EXPORT ROW: " + e.getMessage());
            return false;
        }
    }

