package it.eng.care.domain.flow.core.dto.ExtractionFilter;

import java.util.Date;

public class Field {
    private String fieldId;
    private Date form;
    private Date to;

    public String getFieldId() {
        return fieldId;
    }

    public void setFieldId(String fieldId) {
        this.fieldId = fieldId;
    }

    public Date getForm() {
        return form;
    }

    public void setForm(Date form) {
        this.form = form;
    }

    public Date getTo() {
        return to;
    }

    public void setTo(Date to) {
        this.to = to;
    }
}
