package it.eng.care.domain.flow.core.dto;

import java.io.Serializable;

public class JobTalendFileDTO implements Serializable {

    private static final long serialVersionUID = 1L;

    private String id;
    private JobTalendDTO jobTalend;
    private byte[] job;

    public JobTalendFileDTO() {
    }

    public String getId() {
        return id;
    }

    public void setId(String id) {
        this.id = id;
    }

	public JobTalendDTO getJobTalend() {
		return jobTalend;
	}

	public void setJobTalend(JobTalendDTO jobTalend) {
		this.jobTalend = jobTalend;
	}

	public byte[] getJob() {
		return job;
	}

	public void setJob(byte[] job) {
		this.job = job;
	}


}