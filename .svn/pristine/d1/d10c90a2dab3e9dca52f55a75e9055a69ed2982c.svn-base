		    DateTimeFormatter.ofPattern("d-M-yy HH:mm:ss"),
		    DateTimeFormatter.ofPattern("d-M-yy HH:mm"),
		    DateTimeFormatter.ofPattern("d-M-yy"),

		    // === Formati con separatore "-" (12 ore con AM/PM) ===
		    DateTimeFormatter.ofPattern("dd-MM-yyyy hh:mm:ss a", Locale.ENGLISH),
		    DateTimeFormatter.ofPattern("dd-MM-yyyy hh:mm a", Locale.ENGLISH),
		    DateTimeFormatter.ofPattern("d-M-yyyy hh:mm:ss a", Locale.ENGLISH),
		    DateTimeFormatter.ofPattern("d-M-yyyy hh:mm a", Locale.ENGLISH),
