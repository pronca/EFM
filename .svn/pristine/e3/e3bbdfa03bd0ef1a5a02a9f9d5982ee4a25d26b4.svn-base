        if (validationDate != null) {
        	restrictions.add(builder.equal(rootTabella.get("validationDate"), validationDate));
        }
        
        if (!StringUtils.isEmpty(codiceAzienda)) {
            Path<String> text = rootTabella.get("aziendeLoadedInFile");
            restrictions.add(builder.equal(text, codiceAzienda));
        } 
        
        Expression<Long> count=builder.count(rootTabella);
        
        return criteriaQuery.select(count).where(restrictions.toArray(new Predicate[restrictions.size()]));
        

}

}
