    @Override
    public List<Object[]> checkExtractObsoleta(FlowExportRequestDTO  flowExportDTO) throws SQLException {
        String version = flowExportDTO.getVersion().getId();
        String flow = flowExportDTO.getFlow().getId();
        //Recupero UNIONE FLUSSI
        FormFlowDTO formFlowDTOazi = formFlowService.retrieveOne(flow, version);
        //Recuper FLUSSO_AZIENDALE NON FUNZIONA
        //FormFlowDTO formFlowDTOreg = formFlowService.retrieveOne(flowRegioUnioDO.getFlowRegion().getId(), version);

        //Recupero chiavi Sezione 0
        List<String> pkList = new ArrayList<>();
        for (FormFlowTableFieldDTO formFlowTableFieldDTO : formFlowDTOazi.getFlowTableList().get(0).getFlowTableFieldList()) {
            if (formFlowTableFieldDTO.isPk()) {
                pkList.add(formFlowTableFieldDTO.getName());
            }
        }
        //Creao la SELECT DATE_PROCESSING + pkList
        String campiSelect = "EXTRACTION_ID, DATE_PROCESSING, ";
        for (String pKey : pkList) {
            campiSelect += pKey + ", ";
        }
        if (campiSelect.endsWith(", ")) {
            campiSelect = campiSelect.substring(0, campiSelect.length() - 2);
        }
        //Creao la WHERE DATE_PROCESSING + pkList
        String campiWhere = "FREG.DATE_PROCESSING < F.DATE_PROCESSING AND ";
        for (String pKey : pkList) {
            campiWhere += " FREG." + pKey + " = F." + pKey + " AND ";
        }
        if (campiWhere.endsWith("AND ")) {
            campiWhere = campiWhere.substring(0, campiWhere.length() - 4);
        }
        String selectSQL = "SELECT " + campiSelect +
                " FROM FM_FLOW_" + formFlowDTOazi.getName() + "_REG_" + formFlowDTOazi.getFlowTableList().get(0).getSection() + " FREG " +
                " WHERE EXTRACTION_ID=? AND EXISTS (" +
                " SELECT 1 FROM FM_FLOW_" + formFlowDTOazi.getName() + "_" + formFlowDTOazi.getFlowTableList().get(0).getSection() + " F WHERE " +
                campiWhere + ")";

        LOGGER.debug("SELECT SQL QUERY:" + selectSQL);
        //Lista Object Pratiche errate
        List<Object[]> checkList = new ArrayList<>();

        Session session = entityManager.unwrap(Session.class);
        session.doWork(conn -> {
            // niente getConnection() -> usi quella già associata alla transazione
            try (PreparedStatement ps = conn.prepareStatement(
                    selectSQL,
                    ResultSet.TYPE_FORWARD_ONLY,
                    ResultSet.CONCUR_READ_ONLY)) {

                ps.setFetchSize(5000);

                // IMPORTANTISSIMO: usa il tipo giusto (se EXTRACTION_ID è NUMBER)
                ps.setLong(1, Long.parseLong(flowExportDTO.getId()));

                try (ResultSet rs = ps.executeQuery()) {
                    while (rs.next()) {
                        Object[] row = new Object[pkList.size()];
                        for (int i = 0; i < pkList.size(); i++) {
                            row[i] = rs.getString(pkList.get(i).toUpperCase());
                        }
                        checkList.add(row);
                    }
                }
            }
        });
        
        return checkList;
    }
    
    public Integer consolidaPratiche(FlowExportRequestDTO flowExportDTO, String status) {
    	
        String version = flowExportDTO.getVersion().getId();
        String flow = flowExportDTO.getFlow().getId();
        
        // Recupero configurazione flusso
        FormFlowDTO formFlowDTOazi = formFlowService.retrieveOne(flow, version);
        
        // Recupero chiavi PK sezione 0
        List<String> pkList = new ArrayList<>();
        for (FormFlowTableFieldDTO f : formFlowDTOazi.getFlowTableList().get(0).getFlowTableFieldList()) {
            if (f.isPk()) {
                pkList.add(f.getName());
            }
        }
        
        // Flag join con scarti regionali
        final boolean joinScartoRegionale = status.equals(StateSendRegionEnum.INVIATA.name());
        
        // SQL SELECT regionale
        final String sqlSelectR = generateQuerySelect(
                pkList,
                formFlowDTOazi.getName(),
                formFlowDTOazi.getFlowTableList().get(0).getSection(),
                joinScartoRegionale
        );

        // SQL UPDATE REGIONALE (final)
        String baseUpdateR = "UPDATE FM_FLOW_" + formFlowDTOazi.getName()
                + "_REG_" + formFlowDTOazi.getFlowTableList().get(0).getSection()
                + " SET STATE_SEND_REGION = '" + status + "' "
                + (joinScartoRegionale ? " , STATUS_REGION = ?" : "");

        String whereR = " WHERE EXTRACTION_ID = ? AND ";
        for (String pKey : pkList) {
            whereR += pKey + "=? AND ";
        }
        if (whereR.endsWith("AND ")) {
            whereR = whereR.substring(0, whereR.length() - 4);
        }
        final String sqlUpdateR = baseUpdateR + whereR;

        // SQL UPDATE AZIENDALE (final)
        String baseUpdateA = "UPDATE FM_FLOW_" + formFlowDTOazi.getName()
                + "_" + formFlowDTOazi.getFlowTableList().get(0).getSection()
                + " SET STATE_SEND_REGION = '" + status + "'"
                + (joinScartoRegionale ? " , STATUS_REGION = ?" : "");

        String whereA = " WHERE ";
        for (String pKey : pkList) {
            whereA += pKey + "=? AND ";
        }
        if (whereA.endsWith("AND ")) {
            whereA = whereA.substring(0, whereA.length() - 4);
        }
        final String sqlUpdateA = baseUpdateA + whereA;

        // Final catturabili dalla lambda
        final List<String> pk = pkList;
        final String extractionId = flowExportDTO.getId();

        LOGGER.info("SQL_SELECT_R : {}", sqlSelectR);
        LOGGER.info("SQL_UPDATE_R : {}", sqlUpdateR);
        LOGGER.info("SQL_UPDATE_A : {}", sqlUpdateA);

        final AtomicInteger count = new AtomicInteger(0);

        Session session = entityManager.unwrap(Session.class);
        session.doWork(conn -> {
            try (
                    PreparedStatement psSel = conn.prepareStatement(sqlSelectR);
                    PreparedStatement psUpdR = conn.prepareStatement(sqlUpdateR);
                    PreparedStatement psUpdA = conn.prepareStatement(sqlUpdateA)
            ) {
                psSel.setFetchSize(5000);

                // EXTRACTION_ID è VARCHAR2
                psSel.setString(1, extractionId);

                int batch = 0;

                try (ResultSet rs = psSel.executeQuery()) {
                    while (rs.next()) {

                        int offset = 0;
                        if (joinScartoRegionale) {
                            offset = 1;
                            String severity = rs.getString("SEVERITY_SCARTO_REG");
                            if (severity == null || severity.isBlank()) {
                                severity = "VALIDO";
                            }
                            psUpdR.setString(1, severity);
                            psUpdA.setString(1, severity);
                        }

                        // Update regionale: EXTRACTION_ID nel where
                        psUpdR.setString(1 + offset, rs.getString("EXTRACTION_ID"));

                        // PK params
                        int idxR = 2 + offset; // dopo EXTRACTION_ID (e dopo STATUS_REGION se presente)
                        int idxA = 1 + offset; // aziendale non ha EXTRACTION_ID

                        for (String pKey : pk) {
                            String val = rs.getString(pKey.toUpperCase());
                            psUpdR.setString(idxR++, val);
                            psUpdA.setString(idxA++, val);
                        }

                        psUpdR.addBatch();
                        psUpdA.addBatch();

                        batch++;
                        count.incrementAndGet();

                        if (batch % 1000 == 0) {
                            psUpdA.executeBatch();
                            psUpdR.executeBatch();
                            psUpdA.clearBatch();
                            psUpdR.clearBatch();
                        }
                    }
                }

                // Flush finale
                if (batch % 1000 != 0) {
                    psUpdA.executeBatch();
                    psUpdR.executeBatch();
                }

            } catch (SQLException e) {
                // Propaga: con @Transactional Spring farà rollback
            	LogUtil.logException(LOGGER, "", e);
            	
                throw new RuntimeException("Errore in consolidaPratiche JDBC", e);
            }
        });

        return count.get();
    }

    private static void bindExtractionId(PreparedStatement ps, int index, Object value) throws SQLException {
        if (value == null) {
            ps.setNull(index, Types.NUMERIC);
            return;
        }
        if (value instanceof Number n) {
            ps.setLong(index, n.longValue());
            return;
        }
        String s = String.valueOf(value).trim();
        try {
            ps.setLong(index, Long.parseLong(s));
        } catch (NumberFormatException ex) {
            ps.setString(index, s);
        }
    }

    @Override
    public Integer consolidaRitorni(FormFlowDTO configurationRegion,
                                   FlowExportRequestDTO flowExportDTO,
                                   String status,
                                   Boolean joinScartoRegionale,
                                   TabgenMap tracciatoSegnalazioniRegionali) {

        // Coerente col tuo codice: se non è consolidata non facciamo batch update
        if (flowExportDTO.getConsolidata() == null || !flowExportDTO.getConsolidata()) {
            return 0;
        }

        // --- Config esterna (checkExt) ---
        boolean checkExt = false;
        String sqlUpdateExt = "";
        String tableExt = "";

        ConfigurationDO cfgObj = configuration.findByKeyId("flowWithExternalUpdate");
        if (cfgObj != null && cfgObj.getValue() != null) {
            String[] cfgSplitted = cfgObj.getValue().split("/");
            for (String value : cfgSplitted) {
                int iend = value.indexOf("(");
                if (iend > 0) {
                    String flusso = value.substring(0, iend);
                    String flussoCopia = value.substring(iend + 1, value.length() - 1);
                    if (flusso != null && flusso.equals(flowExportDTO.getFlow().getName())) {
                        checkExt = true;
                        tableExt = "FM_FLOW_" + flussoCopia + "_0";
                        break;
                    }
                }
            }
        }

        final String version = flowExportDTO.getVersion().getId();
        final String flow = flowExportDTO.getFlow().getId();
        final FormFlowDTO formFlowDTOaziendale = formFlowService.retrieveOne(flow, version);

        // PK aziendali sezione 0
        final List<String> azPkList = new ArrayList<>();
        for (FormFlowTableFieldDTO f : formFlowDTOaziendale.getFlowTableList().get(0).getFlowTableFieldList()) {
            if (f.isPk()) azPkList.add(f.getName());
        }

        // PK regionali sezione 0 (della config regionale)
        final List<String> regPkList = new ArrayList<>();
        for (FormFlowTableFieldDTO f : configurationRegion.getFlowTableList().get(0).getFlowTableFieldList()) {
            if (f.isPk()) regPkList.add(f.getName());
        }

        // Campi join con ritorni regionali (solo se joinScartoRegionale=true)
        final boolean joinFinal = Boolean.TRUE.equals(joinScartoRegionale);
        final List<String> joinFieldsWithRegionReturns = new ArrayList<>();
        if (joinFinal && tracciatoSegnalazioniRegionali != null) {
            for (TabgenValueMap j : tracciatoSegnalazioniRegionali.getTabgenValueList()) {
                if (Boolean.TRUE.equals(j.getIsPk())) {
                    joinFieldsWithRegionReturns.add(j.getFieldName());
                }
            }
        }

        // SELECT: unione PK az + PK reg
        Set<String> selectRegSet = new HashSet<>(azPkList);
        selectRegSet.addAll(regPkList);

        String sqlSelectRtmp = generateQuerySelectRitorni(
                new ArrayList<>(selectRegSet),
                joinFieldsWithRegionReturns,
                formFlowDTOaziendale.getName(),
                formFlowDTOaziendale.getFlowTableList().get(0).getSection(),
                joinFinal
        );

        // Se checkExt: aggiungo FLAG_ESTERNO davanti
        if (checkExt) {
            String prefix = "SELECT t1.FLAG_ESTERNO FLAG_ESTERNO, ";
            if (sqlSelectRtmp != null && sqlSelectRtmp.toUpperCase().startsWith("SELECT ")) {
                sqlSelectRtmp = prefix + sqlSelectRtmp.substring("SELECT ".length());
            } else {
                sqlSelectRtmp = prefix + sqlSelectRtmp;
            }

            // preparo UPDATE EXT
            sqlUpdateExt = "UPDATE " + tableExt
                    + " SET STATE_SEND_REGION = '" + status + "'"
                    + (joinFinal ? " , STATUS_REGION = ?" : "");

            String whereExt = " WHERE ";
            for (String pKey : azPkList) whereExt += pKey + "=? AND ";
            if (whereExt.endsWith("AND ")) whereExt = whereExt.substring(0, whereExt.length() - 4);
            sqlUpdateExt += whereExt;

            LOGGER.info("SQL_UPDATE_EXT : {}", sqlUpdateExt);
        }

        // Template UPDATE regionale multi-sezione
        String sqlUpdateRtmpl = "UPDATE FM_FLOW_" + configurationRegion.getName() + "_{SECTION}"
                + " SET STATE_SEND_REGION = '" + status + "'"
                + (joinFinal ? " , STATUS_REGION = ?" : "");

        String whereR = " WHERE EXTRACTION_ID = ? AND ";
        for (String pKey : regPkList) whereR += pKey + "=? AND ";
        if (whereR.endsWith("AND ")) whereR = whereR.substring(0, whereR.length() - 4);
        sqlUpdateRtmpl += whereR;

        // Template UPDATE aziendale multi-sezione
        String sqlUpdateAtmpl = "UPDATE FM_FLOW_" + formFlowDTOaziendale.getName() + "_{SECTION}"
                + " SET STATE_SEND_REGION = '" + status + "'"
                + (joinFinal ? " , STATUS_REGION = ?" : "");

        String whereA = " WHERE ";
        for (String pKey : azPkList) whereA += pKey + "=? AND ";
        if (whereA.endsWith("AND ")) whereA = whereA.substring(0, whereA.length() - 4);
        sqlUpdateAtmpl += whereA;

        // final per lambda
        final String sqlSelectR = sqlSelectRtmp;
        final String sqlUpdateRTemplate = sqlUpdateRtmpl;
        final String sqlUpdateATemplate = sqlUpdateAtmpl;
        final String sqlUpdateExtFinal = sqlUpdateExt;
        final boolean checkExtFinal = checkExt;
        final String extractionId = flowExportDTO.getId();

        LOGGER.info("SQL_SELECT_R : {}", sqlSelectR);
        LOGGER.info("SQL_UPDATE_R_TEMPLATE : {}", sqlUpdateRTemplate);
        LOGGER.info("SQL_UPDATE_A_TEMPLATE : {}", sqlUpdateATemplate);

        final AtomicInteger count = new AtomicInteger(0);
        final AtomicReference<String> regionValidationStatusRef = new AtomicReference<>("VALIDO");

        Session session = entityManager.unwrap(Session.class);
        session.doWork(conn -> {

            PreparedStatement psSelect = null;
            PreparedStatement psUpdateAziendaleExt = null;
            List<PreparedStatement> psUpdateRegList = new ArrayList<>();
            List<PreparedStatement> psUpdateAzList = new ArrayList<>();

            try {
                psSelect = conn.prepareStatement(sqlSelectR);
                psSelect.setFetchSize(5000);
                psSelect.setString(1, extractionId);

                try (ResultSet rs = psSelect.executeQuery()) {

                    // preparo PS per tutte le sezioni (una sola volta)
                    for (FormFlowTableDTO table : formFlowDTOaziendale.getFlowTableList()) {
                        String sql = sqlUpdateATemplate.replace("{SECTION}", String.valueOf(table.getSection()));
                        PreparedStatement ps = conn.prepareStatement(sql);
                        ps.setFetchSize(5000);
                        psUpdateAzList.add(ps);
                        LOGGER.info("SQL_UPDATE_A_SEC : {}", sql);
                    }

                    for (FormFlowTableDTO table : configurationRegion.getFlowTableList()) {
                        String sql = sqlUpdateRTemplate.replace("{SECTION}", String.valueOf(table.getSection()));
                        PreparedStatement ps = conn.prepareStatement(sql);
                        ps.setFetchSize(5000);
                        psUpdateRegList.add(ps);
                        LOGGER.info("SQL_UPDATE_R_SEC : {}", sql);
                    }

                    if (checkExtFinal && sqlUpdateExtFinal != null && !sqlUpdateExtFinal.isBlank()) {
                        psUpdateAziendaleExt = conn.prepareStatement(sqlUpdateExtFinal);
                        psUpdateAziendaleExt.setFetchSize(5000);
                    }

                    int batch = 0;

                    while (rs.next()) {
                        // severity
                        String severity = "VALIDO";
                        if (joinFinal) {
                            String s = rs.getString("SEVERITY_SCARTO_REG");
                            if (s != null && !s.isBlank()) severity = s;
                        }

                        // aggiorna regionValidationStatus (prendo la “massima” severità)
                        String current = regionValidationStatusRef.get();
                        if (severityRankRitorni(severity) >= severityRankRitorni(current)) {
                            regionValidationStatusRef.set(severity);
                        }

                        // --- UPDATE REGIONALE (tutte le sezioni regionali) ---
                        for (PreparedStatement psR : psUpdateRegList) {
                            int idx = 1;
                            if (joinFinal) {
                                psR.setString(idx++, severity);                   // STATUS_REGION
                            }
                            psR.setString(idx++, rs.getString("EXTRACTION_ID")); // EXTRACTION_ID (VARCHAR2)
                            for (String pKey : regPkList) {
                                psR.setString(idx++, rs.getString(pKey.toUpperCase()));
                            }
                            psR.addBatch();
                        }

                        // --- UPDATE AZIENDALE (interno o esterno) ---
                        boolean goExternal = false;
                        if (checkExtFinal) {
                            String flagEsterno = rs.getString("FLAG_ESTERNO");
                            goExternal = (flagEsterno != null && !flagEsterno.isBlank());
                        }

                        if (checkExtFinal && goExternal) {
                            if (psUpdateAziendaleExt != null) {
                                int idx = 1;
                                if (joinFinal) {
                                    psUpdateAziendaleExt.setString(idx++, severity);
                                }
                                for (String pKey : azPkList) {
                                    psUpdateAziendaleExt.setString(idx++, rs.getString(pKey.toUpperCase()));
                                }
                                psUpdateAziendaleExt.addBatch();
                            }
                        } else {
                            for (PreparedStatement psA : psUpdateAzList) {
                                int idx = 1;
                                if (joinFinal) {
                                    psA.setString(idx++, severity);
                                }
                                for (String pKey : azPkList) {
                                    psA.setString(idx++, rs.getString(pKey.toUpperCase()));
                                }
                                psA.addBatch();
                            }
                        }

                        batch++;
                        count.incrementAndGet();

                        if (batch % 1000 == 0) {
                            executeAndClearBatches(psUpdateRegList);
                            executeAndClearBatches(psUpdateAzList);
                            if (psUpdateAziendaleExt != null) {
                                psUpdateAziendaleExt.executeBatch();
                                psUpdateAziendaleExt.clearBatch();
                            }
                        }
                    }

                    // flush finale
                    if (batch % 1000 != 0) {
                        executeAndClearBatches(psUpdateRegList);
                        executeAndClearBatches(psUpdateAzList);
                        if (psUpdateAziendaleExt != null) {
                            psUpdateAziendaleExt.executeBatch();
                            psUpdateAziendaleExt.clearBatch();
                        }
                    }
                }

            } catch (SQLException e) {
            	LogUtil.logException(LOGGER, "", e);
            	
                throw new RuntimeException("Errore in consolidaRitorni JDBC", e);
            } finally {
                // usa il closeQuietly già presente nella tua classe
                closeQuietly(psSelect);
                closeQuietly(psUpdateAziendaleExt);
                for (PreparedStatement ps : psUpdateRegList) closeQuietly(ps);
                for (PreparedStatement ps : psUpdateAzList) closeQuietly(ps);
            }
        });

        // aggiorna stato validazione regionale (con @Transactional verrà flushato a commit)
        FlowExportRequestDO request = entityManager.getReference(FlowExportRequestDO.class, flowExportDTO.getId());
        request.setRegionValidationStatus(regionValidationStatusRef.get());

        return count.get();
    }

    private static void executeAndClearBatches(List<PreparedStatement> list) throws SQLException {
        for (PreparedStatement ps : list) {
            ps.executeBatch();
            ps.clearBatch();
        }
    }

    private static int severityRankRitorni(String s) {
        if (s == null) return 0;
        return switch (s) {
            case "VALIDO" -> 0;
            case "SEGNALAZIONE" -> 1;
            default -> 2; // ERRORE o altro più grave
        };
    }


    private static int severityRank(String s) {
        if (s == null) return 0;
        return switch (s) {
            case "VALIDO" -> 0;
            case "SEGNALAZIONE" -> 1;
            default -> 2; // ERRORE o altro più “grave”
        };
    }

    private static void closeQuietly(AutoCloseable c) {
        if (c != null) try { c.close(); } catch (Exception ignore) {}
    }

    @Override
    public FlowExportRequestDO retriveOne(String id) {
        return (id == null || id.isBlank())
                ? null
                : flowExportDAO.findById(id).orElse(null);
    }

    @Override
    public Boolean logicDelete(List<FlowExportRequestDO> flowExportRequestDOS) {
        try {
            for (FlowExportRequestDO flowExportRequestDO : flowExportRequestDOS) {
                flowExportRequestDO.setDeleted(1);
                flowExportDAO.save(flowExportRequestDO);
            }
            return true;
        } catch (Exception e) {
        	LogUtil.logException(LOGGER, "ERROR (logical) DELETE FLOW EXPORT ROW", e);
            return false;
        }
    }

    @Override
    public Boolean delete() {
        try {
        	//caricamento lista aziende visibili dall'utente
    		List<String> aziende = flowManagerProfileService.getAziendeForUserProfile();
    		
            BaseSearchInput baseSearchInput = new BaseSearchInput();
            baseSearchInput.setValue("deleted", 1);
            baseSearchInput.setParam("aziende", aziende);
            Pair<List<FlowExportRequestDO>, SearchInfo> list = retrieveAllFiltered(baseSearchInput, false);
            for (FlowExportRequestDO flowExportRequestDO : list.getFirst()) {
                //DELETE REGION TABLE
                formFlowService.deletebyExtractionId(flowExportRequestDO.getId(),
                        flowExportRequestDO.getFlow(),
                        flowExportRequestDO.getVersion());
                flowExportDAO.deleteById(flowExportRequestDO.getId());
            }
            return true;
        } catch (Exception e) {
        	LogUtil.logException(LOGGER, "ERROR (physical) DELETE FLOW EXPORT ROW", e);
            return false;
        }
    }

