		@Override
		public HttpEntity<byte[]> downloadXML(String exportId) {
			
			HttpHeaders header = new HttpHeaders();
			header.set("Content-Disposition", "attachment;");

			FlowExportRequestDO example = new FlowExportRequestDO();
			example.setId(exportId);

			List<FlowExportReqFileTalendDO> exports = flowExportReqFileTalendDAO.findAllByflowExportRequest(example);
			List<File> files = new ArrayList<>();
			exports.forEach((FlowExportReqFileTalendDO export) -> {
				try {
					String fileName = export.getFlowExportRequest().getFlow().getName() + "_" + exports.indexOf(export);;
					if(flowManagerProfileService.checkFlowById(export.getFlowExportRequest().getFlow().getId())) {
						if(export.getXml()!=null) {
							byte[] byt = export.getXml();
							File file = File.createTempFile(fileName, export.getFileExt());
							Files.write(byt, file);
							files.add(file);
						}
					}
				} catch (IOException e) {
					LogUtil.logException(LOGGER, "", e);
//					e.printStackTrace();
				}
			});

			if (files != null && files.size() > 0) {
				String[] fileNames = new String[files.size()];
				int i = 0;
				for (File file : files) {
					fileNames[i] = file.getName();
					i++;
				}

				byte[] byt = FileUtility.compressingFiles(files.get(0).getParent(),
						files.get(0).getParent() + "/extraction.zip", fileNames);
				
				if (logAccessiPMConfig != null && "1".equals(logAccessiPMConfig.getAccessLogDownXMLEstrazFlusso())) {
		    		byte[] resultsLogAccessi = sendAuditDownXMLEstrFlussiToPM(exportId, byt);
		        }
		    	
				return new HttpEntity<byte[]>(byt, header);
			}
			return null;
		}

		@Override
		public HttpEntity<byte[]> downloadLog(String exportId) {
			
			HttpHeaders header = new HttpHeaders();
			header.set("Content-Disposition", "attachment;");

			FlowExportRequestDO example = new FlowExportRequestDO();
			example.setId(exportId);

			List<FlowExportReqFileTalendDO> exports = flowExportReqFileTalendDAO.findAllByflowExportRequest(example);
			List<File> files = new ArrayList<>();
			exports.forEach((FlowExportReqFileTalendDO export) -> {
				try {
					String fileName = export.getFlowExportRequest().getFlow().getName() + "_" + exports.indexOf(export);;
					if(flowManagerProfileService.checkFlowById(export.getFlowExportRequest().getFlow().getId())) {
						if(export.getLog()!=null) {
							byte[] byt = export.getLog();
							File file = File.createTempFile(fileName, ".txt");
							Files.write(byt, file);
							files.add(file);
						}
					}
				} catch (IOException e) {
					LogUtil.logException(LOGGER, "", e);
//					e.printStackTrace();
				}
			});

			if (files != null && files.size() > 0) {
				String[] fileNames = new String[files.size()];
				int i = 0;
				for (File file : files) {
					fileNames[i] = file.getName();
					i++;
				}

				byte[] byt = FileUtility.compressingFiles(files.get(0).getParent(),
						files.get(0).getParent() + "/extraction.zip", fileNames);
				
				if (logAccessiPMConfig != null && "1".equals(logAccessiPMConfig.getAccessLogDownLOGEstrazFlusso())) {
		    		byte[] resultsLogAccessi = sendAuditDownLOGEstrFlussiToPM(exportId, byt);
		        }
		    	
				return new HttpEntity<byte[]>(byt, header);
			}
			return null;
		}
		
		@Override
		public Boolean calculateDrg(FlowDrgDO resDrg) {
			String requestId = resDrg.getExtraction().getId();
			FlowExportRequestDO request = flowExportDAO.findById(requestId).orElse(null);
			Object[] respResult = webService.loadAndSimulateFlowOnRegion(requestId, request.getFlow().getName(), true);
			FlussiFile[] result = (FlussiFile[])respResult[0];
			
			if(result != null) {
				resDrg.setReturnDate(new Date());
				org.springframework.statemachine.state.State<String, String> stateDrg;
				try {
					stateDrg = stateMachineFlow.execute(requestId + "_DRG", "DRG", MachineEvent.DRG_TERMINATO_OK.getEvent());
					resDrg.setState(stateDrg.getId());
					flowDrgService.saveDrgResult(resDrg);
				} catch (Exception e) {
					LogUtil.logException(LOGGER, "", e);
//					e.printStackTrace();
				}
				return true;
			}
			
			return false;
		}
		
		@Override
		public void calculateDrgStatistics(FlowDrgDO resDrg) {
			String requestId = resDrg.getExtraction().getId();
			FlowExportRequestDO request = flowExportDAO.findById(requestId).orElse(null);
			String queryString = queryGenerator.generateCountRecordsWithDrgQuery(request.getFlow().getName(), "1");
			Query query = entityManager.createNativeQuery(queryString);
			query.setParameter(1, requestId);
			BigDecimal recordsWithDrg = (BigDecimal)query.getSingleResult();
			resDrg.setNumPratiche(recordsWithDrg.intValue() + "");
			flowDrgService.saveDrgResult(resDrg);
		}
		
