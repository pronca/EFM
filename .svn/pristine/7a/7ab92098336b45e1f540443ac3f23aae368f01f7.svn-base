    @Override
    public FlowExportRequestDO createEntity(FlowExportRequestDO flowExportDO) {
    	Integer id = sequenceService.next(FlowExportRequestDO.class);

        Date requestDate = new Date();
        flowExportDO.setId(id.toString());
        flowExportDO.setRequestDate(requestDate);
        flowExportDO.setRandomId(UUID.randomUUID().toString());

        State<String, String> state = stateMachineFlow.createStateMachine(flowExportDO.getRandomId(), "EXPORT");

        if (state == null) {
            return null;
        } else {
            flowExportDO.setStatus(state.getId());
        }

//        Flag Delete (0 = Inserimento)
        flowExportDO.setDeleted(0);
		flowExportDO = flowExportDAO.save(flowExportDO);

        return flowExportDO;
    }

    @Override
    public FlowExportRequestDO updateEntityRow(FlowExportRequestDO flowExportDO) {
        flowExportDO.setDeleted(0);
        flowExportDO = flowExportDAO.save(flowExportDO);

        return flowExportDO;
    }

    @Override
    public FlowExportRequestDO updateEntity(FlowExportRequestDO flowExportDO) {
    	
    	/*if(useFlowProfile && !flowManagerProfileService.checkFlowById(flowExportDO.getFlow().getId())) {
    		return flowExportDO;
    	}*/

        BaseSearchInput input = new BaseSearchInput();
        input.setValue("extractionID", flowExportDO.getId());
//        FlowConfigurationFilterFieldValueDO value = new FlowConfigurationFilterFieldValueDO();
//
//        FlowExportRequestDO exp = new FlowExportRequestDO();
//        exp.setId(flowExportDO.getId());
//        value.setFlowExportRequest(exp);
//
//        flowConfigurationFilterFieldValueDAO.deleteBy(input);

        List<FlowConfigurationFilterFieldValueDO> listValue = flowConfigurationFilterFieldValueDAO.cerca(input);

        for (FlowConfigurationFilterFieldValueDO values : listValue) {
            flowConfigurationFilterFieldValueDAO.deleteById(values.getId());
        }

        flowExportDO.setDeleted(0);
		flowExportDO = flowExportDAO.save(flowExportDO);

        return flowExportDO;
    }

    @Override
    public Pair<List<FlowExportRequestDO>, SearchInfo> retrieveAllFiltered(BaseSearchInput searchInput, Boolean useFlowProfile) {

        try {
        	if (searchInput.getValue("state")!=null) {
        		String stateId = searchInput.getValue("state").toString();
                String state = stateService.searchState(stateId);
                searchInput.setValue("stateName", state);
        	}
        } catch (Exception e) {
        	LogUtil.logException(LOGGER, "", e);
        }

        int limit = searchInput.getParam("limit");
        int offset = searchInput.getParam("offset");
        Pageable page =  PageRequest.of((offset / limit), limit);

        Long totalItems = flowExportDAO.countFlowExportByFilter(searchInput, useFlowProfile);

        List<FlowExportRequestDO> loList = flowExportDAO.cerca(searchInput, page, useFlowProfile);
        return Pair.of(loList, SearchInfos.create(totalItems));

    }
    
    @Override
    public void invocaJobTalendAnnullaPratica (String flowName, String versionName, Map<String, String> pk) {
		Thread thread = new Thread() {
			@Transactional
			public void run() {
				LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     JOB ANNULLAMENTO PRATICA: Inizio processo invocazione Talend Jar per annullamento pratica    >>>>>>>>>>>>>>>>>>>>>>>");
		    	
				BaseSearchInput poInput = new BaseSearchInput();
				poInput.setValue("flowNameEqual", flowName);
				poInput.setValue("versionNameEqual", versionName);
				List<FlowTableDO> tables = flowTableDAO.cerca(poInput);
				
				FlowTableDO table = tables.stream().filter(t -> t.getSection().equals(0)).findAny().get();
				
		    	// 1. cerca job talend
		    	BaseSearchInput filter = new BaseSearchInput();
		    	String flowDoId = table != null ? table.getFlowDO().getId() : "";
		    	String versionDoId = table != null ? table.getVersionDO().getId() : "";
		    	filter.setParam("flowId", flowDoId);
		    	filter.setParam("version", versionDoId);
		    	List<JobTalendDO> list = jobTalendDAO.cerca(filter, null);
		    	if(list != null && !list.isEmpty()) {
		    		JobTalendDO jobTalend = list.get(0);
		    		JobTalendFileDO jobFile = (jobTalend.getId() == null || jobTalend.getId().isBlank()) ? null : jobTalendFileDAO.findById(jobTalend.getId()).orElse(null);
		    		if(jobFile == null) {
		    			LOGGER.error("<<<<<<<<<<<<<<<<<<<<<<<<<< JOB ANNULLAMENTO PRATICA: JOB TALEND DI ANNULLAMENTO NON TROVATO PER: " + filter.getParam("flowId") + " , " + filter.getParam("version") + " >>>>>>>>>>>>>>>>>>>>>>>>>");
		    			return;
		    		}
		    		
		    		List<String> parameters = new ArrayList<String>();
		            
		            JobTalendDipendencyDO dep = new JobTalendDipendencyDO();
		            dep.setJobTalendFile(jobFile);
		            List<JobTalendDipendencyDO> listDep = jobTalendDependenciesDAO.findAll(Example.of(dep));
		            URL[] urls = new URL[listDep.size()+1];
		            if(listDep.size() > 0) {
		            	for(JobTalendDipendencyDO dipendenza: listDep) {
		                    try {
		    					File dependenceFile = File.createTempFile(dipendenza.getName(), ".jar");
		    					FileUtils.writeByteArrayToFile(dependenceFile, dipendenza.getJar());
		    					urls[listDep.indexOf(dipendenza)] = dependenceFile.toURI().toURL();
		    				} catch (IOException e) {
		    					LogUtil.logException(LOGGER, "", e);
//		    					e.printStackTrace();
		    				}

		            	}
		            }
		            
		            Method methodset = null;
		            Object instance = null;
		            URLClassLoader loader = null;
		            
		            try {
			            LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     JOB ANNULLAMENTO PRATICA: Talend jar trovato, path impostato correttamente -> Creazione Loader    >>>>>>>>>>>>>>>>>>>>>>>");
			
			            loader = WebappClassLoader.newInstance(urls, getClass().getClassLoader());
			            //aggiungo libreria dom4j per la chiamata al jar talend
			            loader.loadClass("org.dom4j.Branch");
			            Class<?> clazz = loader.loadClass(jobTalend.getPackageJob() + "." + jobTalend.getClassName());
			            
			            LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     JOB ANNULLAMENTO PRATICA: Loader funzionante -> Ricerca metodo RunJob     >>>>>>>>>>>>>>>>>>>>>>>");
			
			            instance = clazz.newInstance();
			            methodset = clazz.getMethod("runJob", String[].class);
		            } catch (Exception ex) {
		            	LogUtil.logException(LOGGER, "<<<<<<<<<<<<<<<<<<<<<<<<  JOB ANNULLAMENTO PRATICA: ERRORE(1) >>>>>>>>>>>>>>>>>>>>>>>", ex);
//		            	ex.printStackTrace();
		            	return;
		            }

		            LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     JOB ANNULLAMENTO PRATICA: Metodo riconosciuto -> Impostazione parametri     >>>>>>>>>>>>>>>>>>>>>>>");

		            TalendDbDO talend = talendDbDAO.findById("1").orElse(null);

		            parameters.add("--context= ");
		            parameters.add("--context_param host=" + talend.getHost());
		            parameters.add("--context_param port=" + talend.getPort());
		            parameters.add("--context_param database=" + talend.getDatabase());
		            parameters.add("--context_param username=" + username);
		            parameters.add("--context_param password=" + password);
		            if(table!=null) {
		            	parameters.add("--context_param flowId=" + table.getFlowDO().getId());
		            }
		            parameters.add("--context_param urlJdbc=" + URL);
		            parameters.add("--context_param crypto=" + crypto);
		            parameters.add("--context_param pk=" + pk);


		            LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     JOB ANNULLAMENTO PRATICA: Parametri impostati -> Invocazione metodo RunJob    >>>>>>>>>>>>>>>>>>>>>>>");
		            
		            try {
		            	String[] args = parameters != null ? parameters.toArray(new String[0]) : new String[0];
			            
						Object retObj = methodset.invoke(instance, (Object)args);
						
						loader.close();
		            } catch (Exception ex) {
		            	LogUtil.logException(LOGGER, "<<<<<<<<<<<<<<<<<<<<<<<<  JOB ANNULLAMENTO PRATICA: ERRORE(2) >>>>>>>>>>>>>>>>>>>>>>>", ex);
//		            	ex.printStackTrace();
		            }
		    		
		    	}
		    	
		    	LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     JOB ANNULLAMENTO PRATICA: FINE    >>>>>>>>>>>>>>>>>>>>>>>");
			}
		};
		
		thread.start();
			
    }
    

    @Override
	public Boolean jobTalendJar (String exportId) {
		Boolean result = true;
        FlowExportRequestDO flowExportRequestDO = retriveOne(exportId);
        Set<FlowExportMessageDetailsDO> errorsDO = new HashSet<FlowExportMessageDetailsDO>();
        LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     Inizio processo invocazione Talend Jar     >>>>>>>>>>>>>>>>>>>>>>>");

//        JobTalendDTO jobTalend = flowExportRequestDO.getJobTalendId();
        
        flowExportRequestDO.setStartExtractionDate(new Date());
        try {

            LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     Ricerca jar nel path indicato     >>>>>>>>>>>>>>>>>>>>>>>");

            JobTalendFileDO jobFile = (flowExportRequestDO.getJobTalendId().getId()== null || flowExportRequestDO.getJobTalendId().getId().isBlank()) ? null : jobTalendFileDAO.findById(flowExportRequestDO.getJobTalendId().getId()).orElse(null);
            if (jobFile == null) {
                LOGGER.error("<<<<<<<<<<<<<<<<<<<<<<<<     Talend jar non trovato trovato (id = " + flowExportRequestDO.getJobTalendId().getId() + " >>>>>>>>>>>>>>>>>>>>>>>");
                result = false;
                try {
	                if (!result) {
	                	org.springframework.statemachine.state.State<String, String> stateExtraction = stateMachineFlow.execute(flowExportRequestDO.getId(), "EXPORT", MachineEvent.EXPORT_FAILED.getEvent());
						String state = stateExtraction.getId();
			            if (flowExportRequestDO.getStatus() != state) {
			            	
                            Integer records = talendThreadService.countExtractionRecord(flowExportRequestDO.getId());
                            flowExportRequestDO.setRecord(records.toString());
			                flowExportRequestDO.setStatus(state);
			                flowExportRequestDO.setEndExtractionDate(new Date());
			            }
					} else {
                        Integer records = talendThreadService.countExtractionRecord(flowExportRequestDO.getId());
                        flowExportRequestDO.setRecord(records.toString());
	                    flowExportRequestDO.setEndExtractionDate(new Date());
	                }
//					websocketServer.broadcastFlowExtractRequest("update");

				} catch (Exception e) {
					LogUtil.logException(LOGGER, "", e);
//					e.printStackTrace();
				}
				return false;
            }

            List<String> parameters = new ArrayList<String>();
            
            JobTalendDipendencyDO dep = new JobTalendDipendencyDO();
            dep.setJobTalendFile(jobFile);
            
            List<JobTalendDipendencyDO> listDep = jobTalendDependenciesDAO.findByJobTalendFileId(jobFile.getId());
            URL[] urls = new URL[listDep.size() + 1];
            File[] files = new File[listDep.size()];

            for (int i = 0; i < listDep.size(); i++) {
                JobTalendDipendencyDO dependence = listDep.get(i);
                File dependenceFile = File.createTempFile(dependence.getName(), ".jar");
                FileUtils.writeByteArrayToFile(dependenceFile, dependence.getJar());
                urls[i] = dependenceFile.toURI().toURL();
                files[i] = dependenceFile;
            }

            File file = File.createTempFile(flowExportRequestDO.getJobTalendId().getName(), ".jar");
            FileUtils.writeByteArrayToFile(file, jobFile.getJob());
			urls[listDep.size()] = file.toURI().toURL();

            LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     Talend jar trovato, path impostato correttamente -> Creazione Loader    >>>>>>>>>>>>>>>>>>>>>>>");

            URLClassLoader loader = WebappClassLoader.newInstance(urls, getClass().getClassLoader());
            //aggiungo libreria dom4j per la chiamata al jar talend
            loader.loadClass("org.dom4j.Branch");
            Class<?> clazz = loader.loadClass(flowExportRequestDO.getJobTalendId().getPackageJob() + "." + flowExportRequestDO.getJobTalendId().getClassName());
                        
            LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     Loader funzionante -> Ricerca metodo RunJob     >>>>>>>>>>>>>>>>>>>>>>>");

            Object instance = clazz.newInstance();
            Method methodset = clazz.getMethod("runJob", String[].class);

            LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     Metodo riconosciuto -> Impostazione parametri     >>>>>>>>>>>>>>>>>>>>>>>");

            TalendDbDO talend = talendDbDAO.findById("1").orElse(null); //TODO gestione eccezioni se talend nullo
            
            //caricamento lista aziende visibili dall'utente
            List<String> aziende = flowManagerProfileService.getAziendeForUserProfile();
            
            parameters.add("--context= ");
            parameters.add("--context_param extractionId=" + flowExportRequestDO.getId());
            parameters.add("--context_param host=" + talend.getHost());
            parameters.add("--context_param port=" + talend.getPort());
            parameters.add("--context_param database=" + talend.getDatabase());
            parameters.add("--context_param username=" + username);
            parameters.add("--context_param password=" + password);
            parameters.add("--context_param flowId=" + flowExportRequestDO.getFlow().getId());
            parameters.add("--context_param urlJdbc=" + URL);
            parameters.add("--context_param crypto=" + crypto);
            if (!aziende.isEmpty()) {
            	parameters.add("--context_param aziendeprofilate=" + "'" + String.join("','",aziende) + "'");
			}
            
            LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     Parametri impostati -> Invocazione metodo RunJob    >>>>>>>>>>>>>>>>>>>>>>>");
            
            String[] args = parameters != null ? parameters.toArray(new String[0]) : new String[0];
            
            threadMap.put(exportId, true);
            
            try {
    			Thread thread = new Thread() {
				@Transactional
				public void run() {
					
                    try {
						Object retObj = methodset.invoke(instance, (Object) args);
						
						boolean err = false;
						
						if(threadMap.containsKey(exportId)) {
				    		boolean result = threadMap.get(exportId);
				    		if(result == false) {
				    			retObj = null;		
				    			FlowExportMessageDetailsDO error = new FlowExportMessageDetailsDO();
								error.setErrorValue("Estrazione terminata dall'utente");
								error.setFlowExportRequest(flowExportRequestDO);
								errorsDO.add(error);
					    		err = true;
				    		}
				    		
				    		threadMap.remove(exportId);
				    	}
												
						if (retObj != null && retObj instanceof String[][]) {
							for (String[] strings : (String[][]) retObj) {
								String esito = "0";
								
								if(strings.length > 2) {
									esito = strings[2];
								} else if(strings.length > 0) {
									esito = strings[0];
								}
								
								if(Integer.valueOf(esito) < 0) { //CONTROLLARE CHE NELLA POSIZIONE 2 CI SIA SEMPRE IL CODICE DELL'ERRORE E CHE SIA -1 E CHE NELLA POSIZIONE 0 CI SIA LA DESCRIZIONE
									FlowExportMessageDetailsDO error = new FlowExportMessageDetailsDO();
									error.setErrorValue(strings[0]);
									error.setFlowExportRequest(flowExportRequestDO);
									errorsDO.add(error);
									err = true;
								}
							}
						}
						
						if(!errorsDO.isEmpty()) {
							flowExportRequestDO.setFlowExportMessageDetails(errorsDO);
						}
						
			            loader.close();

                        LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     Metodo invocato correttamente, loader chiuso -> Invocazione StateMachine    >>>>>>>>>>>>>>>>>>>>>>>");

                        String state = "";
                        if(err) {
                        	org.springframework.statemachine.state.State<String, String> stateExtraction = stateMachineFlow.execute(flowExportRequestDO.getId(), "EXPORT", MachineEvent.EXPORT_FAILED.getEvent());
                        	state = stateExtraction.getId();
                        }else {
                        	org.springframework.statemachine.state.State<String, String> stateExtraction = stateMachineFlow.execute(flowExportRequestDO.getId(), "EXPORT", MachineEvent.EXPORT_SUCCESS.getEvent());
                        	state = stateExtraction.getId();
                        }
//        				websocketServer.broadcastFlowExtractRequest("update");
                        LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     StateMachine eseguita correttamente. FINE.     >>>>>>>>>>>>>>>>>>>>>>>");


                        if (!flowExportRequestDO.getStatus().equals(state)) {

                            flowExportRequestDO.setStatus(state);
			                Date date = new Date();
			                Integer records = 0;
			                if(!err) {
			                	records = talendThreadService.countExtractionRecord(flowExportRequestDO.getId());
			                	int check = talendThreadService.checkValidation(flowExportRequestDO.getId());
	                            if(check == 1) {
	                            	flowExportRequestDO.setValidationStatus("NOT_VALID");
	                            }else {
	                            	if(records > 0) {
	                            		flowExportRequestDO.setValidationStatus("XSD_VALIDATED");
	                            	}else {
	                            		flowExportRequestDO.setValidationStatus("NO_ROWS");
	                            	}
	                            }
			                }
                            flowExportRequestDO.setRecord(records.toString());
                            flowExportRequestDO.setEndExtractionDate(date);
                            
                            talendThreadService.save(flowExportRequestDO);
			            } else {
			            	LOGGER.error("PASSAGGIO DI STATO NON PERMESSO");
			            }

                    } catch (Exception ex) {
                    	LogUtil.logException(LOGGER, "", ex);
//						ex.printStackTrace();
						try {
							loader.close();
							LOGGER.info("<<<<<<<<<<<<<<<<<<<<<<<<     Loader chiuso     >>>>>>>>>>>>>>>>>>>>>>>");
                                //FlowExportRequestDO flowExportRequestDO = flowExportDAO.findById(flowExportDTO.getId()).orElse(null);
		                	org.springframework.statemachine.state.State<String, String> stateExtraction = stateMachineFlow.execute(flowExportRequestDO.getId(), "EXPORT", MachineEvent.EXPORT_FAILED.getEvent());
							String state = stateExtraction.getId();
                                if (flowExportRequestDO.getStatus() != state) {
				                flowExportRequestDO.setStatus(state);
//                                Integer records = talendThreadService.countExtractionRecord(flowExportDTO);
                                flowExportRequestDO.setRecord("");
				                flowExportRequestDO.setEndExtractionDate(new Date());
				                FlowExportMessageDetailsDO error = new FlowExportMessageDetailsDO();
								error.setErrorValue("Errore durante l'esecuzione del jar");
								error.setFlowExportRequest(flowExportRequestDO);
								errorsDO.add(error);
								flowExportRequestDO.setFlowExportMessageDetails(errorsDO);
				                talendThreadService.save(flowExportRequestDO);
				            }
						} catch (Exception e) {
							LogUtil.logException(LOGGER, "", e);
//							e.printStackTrace();
						}
			        } finally {
			        	threadMap.remove(exportId);
			        }
				}

                };
                
    			thread.start();
    			
				Thread thread2 = new Thread() {
					public void run() {
						try {
							while(threadMap.containsKey(exportId) && threadMap.get(exportId)) {
								Thread.sleep(10000);
							}
							
							if(thread.isAlive()) {
								Method destroy = clazz.getMethod("destroy");
								destroy.invoke(instance);
								talendThreadService.deleteErrors(exportId);
							}
							
						} catch (Exception e) {
							LogUtil.logException(LOGGER, "", e);
//							e.printStackTrace();
						} 
//						finally {
//							threadMap.remove(exportId);
//						}
					}
				};
				
				thread2.start();
				
    			return true;

    		} catch (Exception e) {
    			LogUtil.logException(LOGGER, "", e);
    			try {
    				loader.close();
                    //FlowExportRequestDO flowExportRequestDO = flowExportDAO.findById(flowExportDTO.getId()).orElse(null);
                	org.springframework.statemachine.state.State<String, String> stateExtraction = stateMachineFlow.execute(flowExportRequestDO.getId(), "EXPORT", MachineEvent.EXPORT_FAILED.getEvent());
					String state = stateExtraction.getId();
                    if (flowExportRequestDO.getStatus() != state) {
		                flowExportRequestDO.setStatus(state);
//                        Integer records = talendThreadService.countExtractionRecord(flowExportDTO);
                        flowExportRequestDO.setRecord("");
		                flowExportRequestDO.setEndExtractionDate(new Date());
		                FlowExportMessageDetailsDO error = new FlowExportMessageDetailsDO();
						error.setErrorValue("Errore durante l'esecuzione del jar");
						error.setFlowExportRequest(flowExportRequestDO);
						errorsDO.add(error);
						flowExportRequestDO.setFlowExportMessageDetails(errorsDO);
		                talendThreadService.save(flowExportRequestDO);
		            }
				} catch (Exception ex) {
					LogUtil.logException(LOGGER, "", ex);
//					ex.printStackTrace();
				}
    			return false;
    		}
        }catch(Exception e) {
        	try {
                //FlowExportRequestDO flowExportRequestDO = flowExportDAO.findById(flowExportDTO.getId()).orElse(null);
            	org.springframework.statemachine.state.State<String, String> stateExtraction = stateMachineFlow.execute(flowExportRequestDO.getId(), "EXPORT", MachineEvent.EXPORT_FAILED.getEvent());
				String state = stateExtraction.getId();
                if (flowExportRequestDO.getStatus() != state) {
	                flowExportRequestDO.setStatus(state);
//                    Integer records = talendThreadService.countExtractionRecord(flowExportDTO);
                    flowExportRequestDO.setRecord("");
	                flowExportRequestDO.setEndExtractionDate(new Date());
	                FlowExportMessageDetailsDO error = new FlowExportMessageDetailsDO();
					error.setErrorValue("Errore durante l'esecuzione del jar");
					error.setFlowExportRequest(flowExportRequestDO);
					errorsDO.add(error);
					flowExportRequestDO.setFlowExportMessageDetails(errorsDO);
	                talendThreadService.save(flowExportRequestDO);
	            }
			} catch (Exception ex) {
				LogUtil.logException(LOGGER, "", e);
//				ex.printStackTrace();
			}
        	return false;
        }
    }
    
    @Override
	public boolean killJob (String exportId) {
    	
    	if(threadMap.containsKey(exportId)) {
    		putInMap(exportId);
    		return true;
    	}else {
    		return false;
    	}
    	
    }
    
    public synchronized void putInMap(String exportId) {
    	threadMap.put(exportId, false);
    }

