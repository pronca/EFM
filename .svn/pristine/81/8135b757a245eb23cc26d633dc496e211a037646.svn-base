package it.eng.care.domain.flow.webservice.sis.ws.login;

import jakarta.xml.bind.annotation.XmlAccessType;
import jakarta.xml.bind.annotation.XmlAccessorType;
import jakarta.xml.bind.annotation.XmlElement;
import jakarta.xml.bind.annotation.XmlRootElement;

@XmlAccessorType(XmlAccessType.FIELD)
@XmlRootElement(name = "getUsernameByTokenResponse", namespace = "http://ws.sis.eng.it/")
public class GetUsernameByTokenResponse {
  @XmlElement(name = "return")
  private String value;

  public String getUsername() { return value; }
}

