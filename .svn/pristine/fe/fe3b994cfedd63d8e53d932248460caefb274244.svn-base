package it.eng.care.domain.flow.core.dto;

import java.io.Serializable;
import java.util.List;


public class AnagrafcaAssistitoPaginationDTO implements Serializable{


	private static final long serialVersionUID = 1L;
	
	private List<AnagraficaAssistitoDTO> anagraficaData;
	private Integer allPages;
	
	public AnagrafcaAssistitoPaginationDTO() {}	
	
	
	public List<AnagraficaAssistitoDTO> getAnagraficaData() {
		return anagraficaData;
	}
	public void setAnagraficaData(List<AnagraficaAssistitoDTO> anagraficaData) {
		this.anagraficaData = anagraficaData;
	}
	public Integer getAllPages() {
		return allPages;
	}
	public void setAllPages(Integer allPages) {
		this.allPages = allPages;
	}
	
	
	
			
}
