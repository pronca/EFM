package it.eng.care.domain.flow.core.dto.FlowConfigurationFilter;

import java.util.ArrayList;
import java.util.Date;
import java.util.List;

public class FlowConfigurationFilterFieldValueDTO {

    String id;
    String singleValue;
    List<String> multiValues = new ArrayList<>();
    Date dateFromValue;
    Date dateToValue;
    String numFromValue;
    String numToValue;
    String exportId;
    String filterId;

    public String getId() {
        return id;
    }

    public void setId(String id) {
        this.id = id;
    }

    public String getSingleValue() {
        return singleValue;
    }

    public void setSingleValue(String singleValue) {
        this.singleValue = singleValue;
    }

    public List<String> getMultiValues() {
        return multiValues;
    }

    public void setMultiValues(List<String> multiValues) {
        this.multiValues = multiValues;
    }

    public Date getDateFromValue() {
        return dateFromValue;
    }

    public void setDateFromValue(Date dateFromValue) {
        this.dateFromValue = dateFromValue;
    }

    public Date getDateToValue() {
        return dateToValue;
    }

    public void setDateToValue(Date dateToValue) {
        this.dateToValue = dateToValue;
    }

    public String getNumFromValue() {
        return numFromValue;
    }

    public void setNumFromValue(String numFromValue) {
        this.numFromValue = numFromValue;
    }

    public String getNumToValue() {
        return numToValue;
    }

    public void setNumToValue(String numToValue) {
        this.numToValue = numToValue;
    }

    public String getExportId() {
        return exportId;
    }

    public void setExportId(String exportId) {
        this.exportId = exportId;
    }

    public String getFilterId() {
        return filterId;
    }

    public void setFilterId(String filterId) {
        this.filterId = filterId;
    }
}
