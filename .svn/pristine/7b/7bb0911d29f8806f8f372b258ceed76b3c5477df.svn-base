package it.eng.care.domain.flow.core.dto;

import java.io.Serializable;


public class AnagraficaAssistitoDownloadDTO implements Serializable {
	
	private static final long serialVersionUID = 1L;
	
	private AnagraficaAssistitoDTO[] anagraficaData;
	private String selectedOption;
	private String filterValue;
	
	public AnagraficaAssistitoDownloadDTO() {
	}

	public AnagraficaAssistitoDTO[] getAnagraficaData() {
		return anagraficaData;
	}

	public void setAnagraficaData(AnagraficaAssistitoDTO[] anagraficaData) {
		this.anagraficaData = anagraficaData;
	}

	public String getSelectedOption() {
		return selectedOption;
	}

	public void setSelectedOption(String selectedOption) {
		this.selectedOption = selectedOption;
	}

	public String getFilterValue() {
		return filterValue;
	}

	public void setFilterValue(String filterValue) {
		this.filterValue = filterValue;
	}

}
