<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    	http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd"
        logicalFilePath="db/changelogs/048"
>
	

	<changeSet id="048" author="gennaro.damelio" failOnError="true" context="fm_flow" >
	 		<comment>Aggiunta tabella FM_FLOW, FM_FLOW_TYPE</comment>
		
		<createTable tableName="FM_FLOW_TYPE" remarks="FM_FLOW_TYPE">
			<column name="FM_ID" type="VARCHAR(128)" remarks="Codice"/>
			<column name="FM_DESCRIPTION" type="VARCHAR(256)" remarks="Descrizione"/>
		</createTable>
		<addPrimaryKey tableName="FM_FLOW_TYPE" columnNames="FM_ID"/>
		
		<createTable tableName="FM_FLOW" remarks="FM_FLOW">
			<column name="FM_ID" type="VARCHAR(128)" remarks="Codice"/>
			<column name="FM_DESCRIPTION" type="VARCHAR(128)" remarks="Descrizione"/>
			<column name="FM_STATUS" type="BOOLEAN" remarks="Stato"/>
			<column name="FM_REMOTE_SEND" type="BOOLEAN" remarks="Invio remoto"/>
			<column name="FM_UNIQUENESS" type="BOOLEAN" remarks="Univocita"/>
			<column name="FM_SCHEDULING" type="BOOLEAN" remarks="Schedulazione"/>
			<column name="FM_TYPE" type="VARCHAR(128)" remarks="Tipo flusso"/>

		</createTable>
		<addPrimaryKey tableName="FM_FLOW" columnNames="FM_ID"/>
		
		<addForeignKeyConstraint baseColumnNames="FM_ID"
            baseTableName="FM_FLOW"
            constraintName="fk_FM_FLOW_FM_FLOW_TYPE"
            deferrable="true"
            initiallyDeferred="true"
            onDelete="CASCADE"
            onUpdate="RESTRICT"
            referencedColumnNames="FM_ID"
            referencedTableName="FM_FLOW_TYPE"/>
		

		
	</changeSet>
	
	
</databaseChangeLog>