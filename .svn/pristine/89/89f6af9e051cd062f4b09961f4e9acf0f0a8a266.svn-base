						descrNew.set(i,sub);
					}
					selectDescriptions.put(position,descrNew.get(i));
					position++;
				}

				querySQL += selectSQL + campiSelect + fromSQl + whereSQL;

			} catch (Exception e) {
				logger.error("Errore nel metodo PraticaViewDAOQueryByBaseSearchInput.createQuery : ",e);
