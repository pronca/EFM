					String fieldCopy = selectFieldsApp[i].substring(0,selectFieldsApp[i].length());
					String[] fieldPoint = fieldCopy.split("\\.");
					selectFields.put(position, fieldPoint[1]);
					if(descrNew.get(i).startsWith(" ")) {
