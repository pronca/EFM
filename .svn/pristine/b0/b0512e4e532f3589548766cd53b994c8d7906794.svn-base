package it.eng.care.domain.flow.webservice.sis.ws.flussi;

import java.math.BigDecimal;
import jakarta.xml.bind.annotation.*;

@XmlAccessorType(XmlAccessType.FIELD)
@XmlRootElement(name = "invioFileResponse", namespace = "http://ws.sis.eng.it/")
public class InvioFileResponse {

  @XmlElement(name = "return")
  private BigDecimal returnValue;

  public BigDecimal getReturnValue() { return returnValue; }
  public void setReturnValue(BigDecimal returnValue) { this.returnValue = returnValue; }
}
