package it.eng.care.domain.flow.core.dto.ExtractionFilter;

import it.eng.care.domain.flow.core.dto.FormFlowConfig.FormFlowDTO;

import java.util.List;

public class ExtractionFilterDTO {

    private boolean status;
    private String extractionId;
    private FormFlowDTO formFlow;
    private List<Field> fields;

    public String getExtractionId() {
        return extractionId;
    }

    public void setExtractionId(String extractionId) {
        this.extractionId = extractionId;
    }

    public boolean isStatus() {
        return status;
    }

    public void setStatus(boolean status) {
        this.status = status;
    }

    public FormFlowDTO getFormFlow() {
        return formFlow;
    }

    public void setFormFlow(FormFlowDTO formFlow) {
        this.formFlow = formFlow;
    }

    public List<Field> getFields() {
        return fields;
    }

    public void setFields(List<Field> fields) {
        this.fields = fields;
    }
}

