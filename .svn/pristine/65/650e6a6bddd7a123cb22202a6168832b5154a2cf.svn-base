package it.eng.care.domain.flow.drools.model.status;

public enum BeanValidationStatusEnum {

	VALID(0), WARNING(1), ERROR(2), TO_VALIDATE(-1), RESET(-2);

	private Integer weight;

	private BeanValidationStatusEnum(Integer weight) {
		this.weight = weight;
	}

	public Integer getWeight() {
		return weight;
	}

}
