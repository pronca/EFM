	public void dropTable(boolean deleteAll, boolean deleteField, boolean deleteValue) {
		Tabgen table = new Tabgen();
		table.setId("TEST_DROP");
		table.setDescription("TEST_DROP");
		table.setFieldNum(1);
		table.setType(TabgenType.ANAGRAFICHE.name());
		table.setVisible(1);
		List<TabgenField> tabgenFields = new ArrayList<TabgenField>();
		TabgenField field1 = new TabgenField();
		field1.setDescription("FIELD1");
		field1.setId("FIELD1");
		field1.setNullable(false);
		field1.setPk(false);
		field1.setProgressive(1);
		field1.setTabgen(table);
		field1.setVisible(true);
		field1.setTabgen(table);
		field1.setTabgenValueColumn("FIELD1");
		tabgenFields.add(field1);
		table.setTabgenFields(tabgenFields);
		TabgenResultBean result = delegate.saveTable(table);
		result = delegate.deleteTable("TEST_DROP", deleteAll, deleteField, deleteValue);
		assertNotNull(result);	
	}
	
