		field3.setDescription("field8");
		field3.setNullable(true);
		field3.setPk(false);
		field3.setProgressive(8);
		field3.setTabgen(table);
		field3.setVisible(true);
		field3.setTabgen(table);
		field3.setTabgenValueColumn("FIELD8");
		fields.add(field3);
		
		TabgenResultBean result = delegate.saveFields(fields , true);
		
		assert(result.getError() != null || result.getFields() != null && !result.getFields().isEmpty());
		
	}
	
