	@Test
	public void saveValue() {
		createTableAnagrafica();
		
		Tabgen table = new Tabgen();
		table.setId("TEST");
		
		String field2 = UUID.randomUUID().toString();
		
		// inserimento
		TabgenValue value = new TabgenValue();
		value.setTabgen(table);
		value.setField1(UUID.randomUUID().toString());
		value.setField2(field2);
		value.setEnabledDate(new Date());
		value.setDisabledDate(new Date());
		
		TabgenResultBean result = delegate.saveValue(value);
		value = result.getValue();
		
		assertNotNull(result);
		assertTrue(result.getError() == null && result.getValue() != null);
		
		this.testTabgenValueId = value.getId();
		
		// campo not null
		value.setField2(null);
		result = delegate.saveValue(value);
		result.getValue();
		
		assertNotNull(result);
		assertTrue(result.getError() != null && result.getError().isNotNullable());
		
		// pk violata
		TabgenValue value2 = new TabgenValue();
		value2.setTabgen(table);
		value2.setField1(UUID.randomUUID().toString());
		value2.setField2(field2);
		value2.setEnabledDate(new Date());
		value2.setDisabledDate(new Date());
		
		result = delegate.saveValue(value2);
		result.getValue();
		
		assertNotNull(result);
		assertTrue(result.getError() != null && result.getError().isViolatedPk());
		
		// inserimento altra riga
		value2.setField2(UUID.randomUUID().toString());
		result = delegate.saveValue(value2);
		assertNotNull(result);
		assertTrue(result.getError() == null && result.getValue() != null);
		
	}
	
