	private void manageError(InvalidTabgenOperationException error, final Object param) {
		// if (result.getError() != null) {
		
		String errorRow = error.getErrorExcelRowNumber() != null ? " Riga errata : " + error.getErrorExcelRowNumber() : "";
		String field = " ";
		if (error.getFields() != null && error.getFields().size() > 0) {
			for (String f : error.getFields()) {
				field += f + " ";
			}
		}
		if (error.getOperation().equals(OperationTypeEnum.SAVING_UPDATING_TABLE)) {
			if (error.isTableAssociatedValues()) {
				System.out.println("Attenzione - Impossibile salvare la tabella. Ci sono valori ad essa associati" + errorRow);
			} else if (error.isViolatedPk()) {
				System.out.println("Attenzione - L'identificativo scelto è già stato assegnato" + errorRow);
			}
		} else if (error.getOperation().equals(OperationTypeEnum.SAVING_UPDATING_FIELD)) {
			if (error.isDuplicatedProgressive()) {
				System.out.println("Attenzione - Impossibile salvare i campi. Progressivo campo duplicato per " + field + errorRow);
			} else if (error.isInvalidValueColumnName()) {
				System.out.println("Attenzione - Impossibile salvare i campi. Nome campo non valido : " + field + errorRow);
			} else if (error.isDuplicatedValueColumnName()) {
				System.out.println("Attenzione - Impossibile salvare i campi. Nome campo duplicato : " + error.getFieldTable() + errorRow);
			} else if (error.isFieldReferencingFields()) {
				System.out.println("Attenzione - Impossibile salvare i campi. Esistono riferimenti al campo " + field + errorRow);
			} else if (error.isFieldAssociatedValues()) {
				System.out.println("Attenzione - Impossibile salvare. Campo " + field + " valorizzato" + errorRow);
			} else if (error.isNotEnablingNotNullable()) {
				System.out.println("Attenzione - Impossibile rendere il campo " + field + " obbligatorio" + errorRow);
			} else if (error.isNotEnablingFk()) {
				System.out.println("Attenzione - Impossibile abilitare il riferimento ad altro campo per " + field + errorRow);
			} else if (error.isNotEnablingPk()) {
				System.out.println("Attenzione - Impossibile abilitare il vincolo su tabella per il campo " + field + errorRow);
			} else if (error.isNotDisablingPk()) {
				System.out.println("Attenzione - Impossibile disabilitare il vincolo su tabella per il campo " + field + errorRow);
			}
		} else if (error.getOperation().equals(OperationTypeEnum.SAVING_UPDATING_VALUE)) {
			if (error.getAbsentValueField() != null) {
				System.out.println("Attenzione - Impossibile salvare. Campo " + error.getAbsentValueField() + " inesistente" + errorRow);
			} else if (error.isViolatedFk() && error.getViolatedFkRefField() != null) {
				System.out.println("Attenzione - Impossibile salvare il campo " + error.getViolatedFkField() + ". Chiave esterna " + //
						error.getValue() + " non trovata in " + error.getViolatedFkRefFieldTable() + " - " + error.getViolatedFkRefField() + errorRow);
			} else if (error.isViolatedFk()) {
				System.out.println("Attenzione - Impossibile salvare. Campo " + error.getViolatedFkField() + " referenziato da altri campi" + errorRow);
			} else if (error.isNotNullable()) {
				System.out.println("Attenzione - Impossibile salvare. Campo " + error.getNotNullableField() + " obbligatorio" + errorRow);
			} else if (error.isTableAssociatedValues()) {
				System.out.println("Errore - Esistono dei campi e dei valori associati alla tabella. Solo la descrizione può essere modificata" + errorRow);
			} else if (error.isDuplicatedProgressive()) {
				System.out.println("Errore - Progressivo duplicato per il campo " + field + ". Modificare i campi della tabella" + errorRow);
			} else if (error.isDuplicatedValueColumnName()) {
				System.out.println("Errore - Campo duplicato. Modificare i nomi dei campi:" + field + errorRow);
			} else if (error.getAbsentValueField() != null) {
				System.out.println("Errore - Il campo " + error.getAbsentValueField() + " non esiste per la tabella selezionata" + errorRow);
			} else if (error.isViolatedFk()) {
				System.out.println("Errore - Chiave esterna " + error.getViolatedFkRefField() + "non valida sul campo " + error.getViolatedFkField() + errorRow);
			} else if (error.isNotNullable()) {
				System.out.println("Errore - Il campo " + error.getNotNullableField() + " deve essere valorizzato" + errorRow);
			} else if (error.isViolatedPk()) {
				System.out.println("Errore - Vincolo pk violato su " + error.getValueTable() + errorRow);
			}
		} else if (error.getOperation().equals(OperationTypeEnum.DELETING_TABLE)) {
			if (error.isTableAssociatedFields() && !error.isTableAssociatedValues()) {
				System.out.println("Attenzione - Impossibile cancellare la tabella. Ci sono campi ad essa associati." + errorRow + " Continuare?");
				// SE L'UTENTE CONFERMA INVOCARE IL METODO CON I PARAMETRI INDICATI
				dropTable(true, true, false);
			} else if (error.isTableAssociatedValues()) {
				System.out.println("Attenzione - Impossibile cancellare la tabella. Ci sono valori ad essa associati." + errorRow + " Continuare?");
				// SE L'UTENTE CONFERMA INVOCARE IL METODO CON I PARAMETRI INDICATI
				dropTable(true, true, true);
			}
		} else if (error.getOperation().equals(OperationTypeEnum.DELETING_FIELD)) {
			if (error.isFieldAssociatedValues()) {
				System.out.println("Attenzione - Impossibile cancellare il campo " + field + ". Valore presente." + errorRow + " Continuare?");
				
				// SE L'UTENTE CONFERMA INVOCARE IL METODO CON I PARAMETRI INDICATI
				
				// INVOCARE SE CLICK SU CANCELLA CAMPO
				deleteField(true);
				
				// INVOCARE SE CLICK SU CANCELLA TUTTI I CAMPI
				deleteAllFields(true);
			} else if (error.isFieldReferencingFields()) {
				System.out.println("Attenzione - Impossibile cancellare il campo" + field + ". Riferimenti esterni presenti:" + error.getReferencingFields() + errorRow + ". Continuare?");
				
				// SE L'UTENTE CONFERMA INVOCARE IL METODO CON I PARAMETRI INDICATI
				
				// INVOCARE SE CLICK SU CANCELLA CAMPO
				deleteField(true);
				
				// INVOCARE SE CLICK SU CANCELLA TUTTI I CAMPI
				deleteAllFields(true);
			} else {
				System.out.println("Attenzione - Impossibile cancellare il campo" + field + ". Non e' possibile cancellare colonne di una tabella di transcodifica." + errorRow);
			}

		} else if (error.getOperation().equals(OperationTypeEnum.DELETING_VALUE)) {
			if (error.isValueReferencingValues()) {
				System.out.println("Info - Alcune righe hanno un riferimento al campo " + error.getViolatedFkField() + " per il valore " + error.getValue() + errorRow + ". Continuare?");
				
				// SE L'UTENTE CONFERMA INVOCARE IL METODO CON I PARAMETRI INDICATI
				
				// INVOCARE SE CLICK SU CANCELLA RECORD
				deleteValue(true);
				
				// INVOCARE SE CLICK SU CANCELLA TUTTI I RECORD
				deleteAllValues(true);
			}
		} else if (error.getOperation().equals(OperationTypeEnum.SAVING_TRANSCODE_TABLE)) {
			if (error.isDuplicatedTable()) {
				System.out.println("Attenzione - L'identificativo scelto è già stato assegnato" + errorRow);
			}
		}

	}
	
	

}

