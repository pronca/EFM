package it.eng.care.domain.flow.flowupload.bean;

public enum WellFormedStatusEnum {
	
	LOADED("CARICATO"), COMPLETE("COMPLETO"), INCOMPLETE("INCOMPLETO"), WELL_FORMED("BEN FORMATO"), NOT_WELL_FORMED("NON BEN FORMATO"), VALIDATED("VALIDATO"), VALIDATION_ERROR("VALIDAZIONE FALLITA"), IN_IMPORT("IN FASE DI IMPORTAZIONE");
	
	private String description;
	
	private WellFormedStatusEnum(String descr) {
		this.description = descr;
	}

	public String getDescription() {
		return description;
	}


}
