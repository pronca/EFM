Insert into FM_TABGEN_VALUE (TABGEN_ID,FIELD1,FIELD2,FIELD3,FIELD4,FIELD5,FIELD6,FIELD7,FIELD8,FIELD9,FIELD10,FIELD11,FIELD12,FIELD13,FIELD14,FIELD15,FIELD16,FIELD17,FIELD18,FIELD19,FIELD20,DT_ENABLE,DT_DISABLE,ALWAYS_ENABLED,OPERATION_DATE,TV_ID,FIELD21,FIELD22,FIELD23,FIELD24,FIELD25,FIELD26,FIELD27,FIELD28,FIELD29,FIELD30,FIELD31,FIELD32,FIELD33,FIELD34,FIELD35,FIELD40,FIELD36,FIELD37,FIELD38,FIELD39) values ('FM_DASHBOARD_CONFIG','0012','4d971f52-0716-47bc-9255-5e9ca8f0d028','SCARTO_DATI_CLINICI','SELECT     mese,     anno,     nvl(v, 0) FROM     dashboardmeseanno left     JOIN (         SELECT             month_rif,             year_rif,             SUM(to_number(replace(regexp_replace(nvl(importolordo, ''0''), ''0[0*]0,[0*]0'', ''0''), '','', ''.''))) v         FROM             fm_flow_emur_ps_1 p         WHERE             status = ''ERROR''             AND month_rif IN (                 :mesi             )             AND year_rif IN (                 :anni             )             OR EXISTS (                 SELECT                     1                 FROM                     fm_flow_emur_ps_2 q                 WHERE                     p.codiceazienda = q.codiceazienda                     AND p.codicestruttura = q.codicestruttura                     AND p.codiceaccessops = q.codiceaccessops                     AND q.status = ''ERROR''                     AND q.month_rif IN (                         :mesi                     )                     AND q.year_rif IN (                         :anni                     )             )             OR EXISTS (                 SELECT                     1                 FROM                     fm_flow_emur_ps_3 q                 WHERE                     p.codiceazienda = q.codiceazienda                     AND p.codicestruttura = q.codicestruttura                     AND p.codiceaccessops = q.codiceaccessops                     AND q.status = ''ERROR''                     AND q.month_rif IN (                         :mesi                     )                     AND q.year_rif IN (                         :anni                     )             )         GROUP BY             month_rif,             year_rif     ) ON mese = month_rif          AND anno = year_rif where mese IN (     :mesi ) AND anno IN (     :anni )ORDER BY to_number(anno), to_number(mese)','Scarto Dati Clinici',null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,to_date('01-JAN-00','DD-MON-RR'),to_date('01-JAN-00','DD-MON-RR'),null,to_date('17-FEB-20','DD-MON-RR'),'f3230d2d-4646-4b4e-a833-2cb47c7929c1',null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null);
