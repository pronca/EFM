icepresidio = q.codicepresidio                    AND p.progressivosdo = q.progressivosdo                    AND q.status  = ''ERROR''and q.month_rif in (:mesi)            and q.year_rif in (:anni)            )        GROUP BY            month_rif,            year_rif    ) ON mese = month_rif         AND anno = year_rif         where mese in (:mesi)         and anno in (:anni)ORDER BY    to_number(anno),    to_number(mese)','Scarto Dati Clinici',null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,to_date('01-JAN-00','DD-MON-RR'),to_date('01-JAN-00','DD-MON-RR'),null,to_date('17-FEB-20','DD-MON-RR'),'34e198d0-f7bb-4fca-ba35-3daf74e54a5f',null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null);
