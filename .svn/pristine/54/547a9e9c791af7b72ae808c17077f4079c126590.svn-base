Insert into FM_TABGEN_VALUE (TABGEN_ID,FIELD1,FIELD2,FIELD3,FIELD4,FIELD5,FIELD6,FIELD7,FIELD8,FIELD9,FIELD10,FIELD11,FIELD12,FIELD13,FIELD14,FIELD15,FIELD16,FIELD17,FIELD18,FIELD19,FIELD20,DT_ENABLE,DT_DISABLE,ALWAYS_ENABLED,OPERATION_DATE,TV_ID,FIELD21,FIELD22,FIELD23,FIELD24,FIELD25,FIELD26,FIELD27,FIELD28,FIELD29,FIELD30,FIELD31,FIELD32,FIELD33,FIELD34,FIELD35,FIELD40,FIELD36,FIELD37,FIELD38,FIELD39) values ('FM_DASHBOARD_CONFIG','0017','4d971f52-0716-47bc-9255-5e9ca8f0d028','RICAVI_TOTALI','SELECT
    z.mese,
    z.anno,
    (
        SELECT
            nvl(SUM(to_number(replace(regexp_replace(nvl(importolordo, ''0''), ''0[0*]0,[0*]0'', ''0''), '','', ''.''))), ''0'') v
        FROM
            fm_flow_emur_ps_1 p
        WHERE
            p.status_group = ''VALID''
            AND p.month_rif = to_number(z.mese)
            AND p.year_rif = to_number(z.anno)
            AND p.month_rif IN (
                :mesi
            )
            AND p.year_rif IN (
                :anni
            )
    ) tot
FROM
    dashboardmeseanno z
WHERE
    z.mese IN (
        :mesi
    )
    AND z.anno IN (
        :anni
    )','Ricavi Totali','card-header-primary','attach_money','Ricavi totali','TRUE','AZIENDALE',null,null,null,null,null,null,null,null,null,null,to_date('01-JAN-00','DD-MON-RR'),to_date('01-JAN-00','DD-MON-RR'),null,to_date('05-FEB-20','DD-MON-RR'),'059f8384-da24-46ee-a083-b98b249d1e97',null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null);
Insert into FM_TABGEN_VALUE (TABGEN_ID,FIELD1,FIELD2,FIELD3,FIELD4,FIELD5,FIELD6,FIELD7,FIELD8,FIELD9,FIELD10,FIELD11,FIELD12,FIELD13,FIELD14,FIELD15,FIELD16,FIELD17,FIELD18,FIELD19,FIELD20,DT_ENABLE,DT_DISABLE,ALWAYS_ENABLED,OPERATION_DATE,TV_ID,FIELD21,FIELD22,FIELD23,FIELD24,FIELD25,FIELD26,FIELD27,FIELD28,FIELD29,FIELD30,FIELD31,FIELD32,FIELD33,FIELD34,FIELD35,FIELD40,FIELD36,FIELD37,FIELD38,FIELD39) values ('FM_DASHBOARD_CONFIG','0018','4d971f52-0716-47bc-9255-5e9ca8f0d028','DATI_CLINICI_ERRATI','SELECT    z.mese,    z.anno,    nvl(v, 0)FROM    dashboardmeseanno z    LEFT JOIN (        SELECT            p.month_rif,            p.year_rif,            COUNT(1) v        FROM            fm_flow_emur_ps_1 p            LEFT JOIN fm_flow_emur_ps_2 q ON p.codiceazienda = q.codiceazienda                                           AND p.codicestruttura = q.codicestruttura                                           AND p.codiceaccessops = q.codiceaccessops                                           AND p.status = q.status            LEFT JOIN fm_flow_emur_ps_3 w ON p.codiceazienda = w.codiceazienda                                           AND p.codicestruttura = w.codicestruttura                                           AND p.codiceaccessops = w.codiceaccessops                                           AND p.status = w.status        WHERE            p.status =  ''ERROR''            and p.month_rif in (:mesi)and p.year_rif in (:anni)        GROUP BY            p.month_rif,            p.year_rif    ) c ON z.mese = month_rif           AND z.anno = year_rif           where z.mese in (:mesi)and z.anno in (:anni)ORDER BY    to_number(z.anno),    to_number(z.mese)','Dati Clinici Errati',null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,to_date('01-JAN-00','DD-MON-RR'),to_date('01-JAN-00','DD-MON-RR'),null,to_date('17-FEB-20','DD-MON-RR'),'a6fdbf72-2d53-4dcd-bdd4-32b1c94586f8',null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,