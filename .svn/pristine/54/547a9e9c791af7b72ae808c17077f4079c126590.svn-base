Insert into FM_TABGEN_VALUE (TABGEN_ID,FIELD1,FIELD2,FIELD3,FIELD4,FIELD5,FIELD6,FIELD7,FIELD8,FIELD9,FIELD10,FIELD11,FIELD12,FIELD13,FIELD14,FIELD15,FIELD16,FIELD17,FIELD18,FIELD19,FIELD20,DT_ENABLE,DT_DISABLE,ALWAYS_ENABLED,OPERATION_DATE,TV_ID,FIELD21,FIELD22,FIELD23,FIELD24,FIELD25,FIELD26,FIELD27,FIELD28,FIELD29,FIELD30,FIELD31,FIELD32,FIELD33,FIELD34,FIELD35,FIELD40,FIELD36,FIELD37,FIELD38,FIELD39) values ('FM_DASHBOARD_CONFIG','0030','4d971f52-0716-47bc-9255-5e9ca8f0d028','ERRORI_REG','SELECT
    mese,
    anno,
    nvl(c, 0)
FROM
    dashboardmeseanno left
    JOIN (
        SELECT
            COUNT(1) c,
            month_rif,
            year_rif
        FROM
            fm_flow_emur_ps_0
            JOIN emur_ps_reg_scarti_regione ON emur_ps_reg_scarti_regione.codiceazienda = fm_flow_emur_ps_0.codiceazienda
                                             AND emur_ps_reg_scarti_regione.codicestruttura = fm_flow_emur_ps_0.codicestruttura
                                             AND
                                             fm_flow_emur_ps_0.codiceaccessops in (
                                                  select codiceaccessops
                                                  from fm_flow_emur_ps_reg_0 reg where
                                                    reg.kcodiceaccessops = emur_ps_reg_scarti_regione.kcodiceaccessops and
                                                    reg.CODICEAZIENDA = emur_ps_reg_scarti_regione.CODICEAZIENDA and
                                                    reg.codicestruttura = emur_ps_reg_scarti_regione.codicestruttura)
        WHERE
            month_rif IS NOT NULL
            AND year_rif IS NOT NULL
            AND month_rif IN (
                :mesi
            )
            AND year_rif IN (
                :anni
            )
        GROUP BY
            month_rif,
            year_rif
    ) a ON mese = month_rif
           AND anno = year_rif
WHERE
    mese IN (
        :mesi
    )
    AND anno IN (
        :anni
    )
ORDER BY
    to_number(anno),
    to_number(mese)','Errori Regionali','card-header-danger','error','Visualizza errori regionali','TRUE','REGIONALE','ERRORI',null,null,null,null,null,null,null,null,null,to_date('01-JAN-00','DD-MON-RR'),to_date('01-JAN-00','DD-MON-RR'),null,to_date('05-FEB-20','DD-MON-RR'),'fbb42d01-1100-481c-8f99-3045aa58a4e8',null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null);
Insert into FM_TABGEN_VALUE (TABGEN_ID,FIELD1,FIELD2,FIELD3,FIELD4,FIELD5,FIELD6,FIELD7,FIELD8,FIELD9,FIELD10,FIELD11,FIELD12,FIELD13,FIELD14,FIELD15,FIELD16,FIELD17,FIELD18,FIELD19,FIELD20,DT_ENABLE,DT_DISABLE,ALWAYS_ENABLED,OPERATION_DATE,TV_ID,FIELD21,FIELD22,FIELD23,FIELD24,FIELD25,FIELD26,FIELD27,FIELD28,FIELD29,FIELD30,FIELD31,FIELD32,FIELD33,FIELD34,FIELD35,FIELD40,FIELD36,FIELD37,FIELD38,FIELD39) values ('FM_DASHBOARD_CONFIG','0016','4d971f52-0716-47bc-9255-5e9ca8f0d028','ERRORI_DISTINCT','SELECT
    mese,
    anno,
    SUM(nvl(mes, 0))
FROM
    dashboardmeseanno left
    JOIN (
        SELECT
            COUNT(distinct b.message) mes,
            a.month_rif,
            a.year_rif
        FROM
            fm_flow_emur_ps_0 a
            LEFT JOIN fm_flow_emur_ps_0_message b ON ( a.codiceazienda = b.codiceazienda
                                                     AND a.codicestruttura = b.codicestruttura
                                                     AND a.codiceaccessops = b.codiceaccessops )
        WHERE
            a.month_rif IS NOT NULL
            AND a.year_rif IS NOT NULL
            and a.month_rif in (:mesi)
and a.year_rif in (:anni)
AND B.SEVERITY = ''ERROR''
        GROUP BY
            a.year_rif,
            a.month_rif
        UNION ALL
        SELECT
            COUNT(distinct b.message) mes,
            a.month_rif,
            a.year_rif
        FROM
            fm_flow_emur_ps_1 a
            LEFT JOIN fm_flow_emur_ps_1_message b ON ( a.codiceazienda = b.codiceazienda
                                                     AND a.codicestruttura = b.codicestruttura
                                                     AND a.codiceaccessops = b.codiceaccessops )
        WHERE
            a.month_rif IS NOT NULL
            AND a.year_rif IS NOT NULL
            and a.month_rif in (:mesi)
and a.year_rif in (:anni)
AND B.SEVERITY = ''ERROR''
        GROUP BY
            a.year_rif,
            a.month_rif
        UNION ALL
        SELECT
            COUNT(distinct b.message) mes,
            a.month_rif,
            a.year_rif
        FROM
            fm_flow_emur_ps_2 a
            LEFT JOIN fm_flow_emur_ps_2_message b ON ( a.codiceazienda = b.codiceazienda
                                                     AND a.codicestruttura = b.codicestruttura
                                                     AND a.codiceaccessops = b.codiceaccessops
                                                     AND b.progressivoprestazione = a.progressivoprestazione )
        WHERE
            a.month_rif IS NOT NULL
            AND a.year_rif IS NOT NULL
            and a.month_rif in (:mesi)
and a.year_rif in (:anni)
AND B.SEVERITY = ''ERROR''
        GROUP BY
            a.year_rif,
            a.month_rif
        UNION ALL
        SELECT
            COUNT(distinct b.message) mes,
            a.month_rif,
            a.year_rif
        FROM
            fm_flow_emur_ps_3 a
            LEFT JOIN fm_flow_emur_ps_3_message b ON ( a.codiceazienda = b.codiceazienda
                                                     AND a.codicestruttura = b.codicestruttura
                                                     AND a.codiceaccessops = b.codiceaccessops
                                                     AND b.progressivodiagnosi = a.progressivodiagnosi )
        WHERE
            a.month_rif IS NOT NULL
            AND a.year_rif IS NOT NULL
            and a.month_rif in (:mesi)
and a.year_rif in (:anni)
AND B.SEVERITY = ''ERROR''
        GROUP BY
            a.year_rif,
            a.month_rif
    ) q ON mese = month_rif
           AND anno = year_rif
           where mese in (:mesi)
and anno in (:anni)
GROUP BY
    mese,
    anno
ORDER BY
    to_number(anno),
    to_number(mese)','Errori Distinct',null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,to_date('01-JAN-00','DD-MON-RR'),to_date('01-JAN-00','DD-MON-RR'),null,null,'f7c95857-174e-414d-9417-d0166da73272',null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null);
