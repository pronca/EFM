    z.mese,
    z.anno,
    (
        SELECT
            nvl(SUM(to_number(replace(regexp_replace(nvl(importolordo, ''0''), ''0[0*]0,[0*]0'', ''0''), '','', ''.''))), 0) v
        FROM
            fm_flow_emur_ps_1 p
            JOIN fm_flow_emur_ps_0 q ON p.codiceazienda = q.codiceazienda
                                       AND p.codicestruttura = q.codicestruttura
