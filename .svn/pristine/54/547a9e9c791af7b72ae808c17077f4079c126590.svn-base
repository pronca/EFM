    mese,
    anno,
    nvl(c, 0)
FROM
    dashboardmeseanno left
    JOIN (
        SELECT
            COUNT(1) c,
            month_rif,
            year_rif
        FROM
            fm_flow_sdo_0
        WHERE
            month_rif IS NOT NULL
            AND year_rif IS NOT NULL
            AND (state_send_region = ''INVIATA''
            OR state_send_region = ''ACCETTATA'')
            and month_rif in (:mesi)
and year_rif in (:anni)
        GROUP BY
            month_rif,
            year_rif
    ) a ON mese = month_rif
           AND anno = year_rif
           where mese in (:mesi)
and anno in (:anni)
