package it.eng.care.domain.flow.core.dto;

import java.util.HashMap;
import java.util.List;

import it.eng.care.domain.flow.core.dto.FormFlowConfig.FormFlowTableFieldDTO;

public class PaginatedPraticaDTO {

	
	private List<Object[]> objectList;
	private Integer countTotal;
	private HashMap<Integer,String> praticaViewFields;
	private HashMap<Integer,String> praticaViewFieldsDescription;
	private List<FormFlowTableFieldDTO> filters;
	private List<String> pkList;
	private boolean queryDetail;
	private List<String> errors;
	
	public List<Object[]> getObjectList() {
		return objectList;
	}
	public void setObjectList(List<Object[]> objectList) {
		this.objectList = objectList;
	}
	public Integer getCountTotal() {
		return countTotal;
	}
	public void setCountTotal(Integer countTotal) {
		this.countTotal = countTotal;
	}
	public HashMap<Integer,String> getPraticaViewFields() {
		return praticaViewFields;
	}
	public void setPraticaViewFields(HashMap<Integer,String> praticaViewFields) {
		this.praticaViewFields = praticaViewFields;
	}
	public HashMap<Integer,String> getPraticaViewFieldsDescription() {
		return praticaViewFieldsDescription;
	}
	public void setPraticaViewFieldsDescription(HashMap<Integer,String> praticaViewFieldsDescription) {
		this.praticaViewFieldsDescription = praticaViewFieldsDescription;
	}
	public List<FormFlowTableFieldDTO> getFilters() {
		return filters;
	}
	public void setFilters(List<FormFlowTableFieldDTO> filters) {
		this.filters = filters;
	}
	public List<String> getPkList() {
		return pkList;
	}
	public void setPkList(List<String> pkList) {
		this.pkList = pkList;
	}
	public boolean isQueryDetail() {
		return queryDetail;
	}
	public void setQueryDetail(boolean queryDetail) {
		this.queryDetail = queryDetail;
	}
	public List<String> getErrors() {
		return errors;
	}
	public void setErrors(List<String> errors) {
		this.errors = errors;
	}
	
	
}
