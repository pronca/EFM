package it.eng.care.domain.flow.b2b.model;

public class ProcessSingleFlowResult {
	private ErrorWellFormedDTO response;
	private String extractionId;
	private boolean success;

	public ProcessSingleFlowResult() {
	}

	public ProcessSingleFlowResult(ErrorWellFormedDTO response, String extractionId, boolean success) {
		this.response = response;
		this.extractionId = extractionId;
		this.success = success;
	}

	public ErrorWellFormedDTO getResponse() {
		return response;
	}

	public void setResponse(ErrorWellFormedDTO response) {
		this.response = response;
	}

	public String getExtractionId() {
		return extractionId;
	}

	public void setExtractionId(String extractionId) {
		this.extractionId = extractionId;
	}

	public boolean isSuccess() {
		return success;
	}

	public void setSuccess(boolean success) {
		this.success = success;
	}
}
