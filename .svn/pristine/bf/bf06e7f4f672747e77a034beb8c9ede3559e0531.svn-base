package it.eng.care.domain.flow.drools.service.impl;

import java.io.File;
import java.io.IOException;
import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

import org.kie.api.KieServices;
import org.kie.api.builder.KieBuilder;
import org.kie.api.builder.KieFileSystem;
import org.kie.api.builder.Message;
import org.kie.api.builder.Message.Level;
import org.kie.api.io.Resource;
import org.kie.api.io.ResourceType;
import org.kie.api.runtime.KieContainer;
import org.kie.api.runtime.KieSession;
import org.kie.api.runtime.rule.FactHandle;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Autowired;

import it.eng.care.domain.flow.core.dao.ErrorMessageDAO;
import it.eng.care.domain.flow.core.entity.ErrorMessageDO;
import it.eng.care.domain.flow.core.entity.SecondLevelValidationRequestDO;
import it.eng.care.domain.flow.drools.model.row.ValidationBean;
import it.eng.care.domain.flow.drools.model.rule.KieSessionWrapper;
import it.eng.care.domain.flow.drools.service.api.DroolsService;
import it.eng.care.domain.flow.drools.service.api.RuleManagerService;
import it.eng.care.domain.flow.drools.utility.api.DroolsDateUtility;
import it.eng.care.domain.flow.drools.utility.api.DroolsQueryUtility;
import it.eng.care.domain.flow.drools.utility.api.DroolsStringUtility;
import it.eng.care.domain.flow.drools.utility.api.DroolsUtility;
import it.eng.care.domain.flow.drools.utility.api.FlowRowUtility;
import it.eng.care.domain.flow.drools.utility.api.LookupUtility;
import it.eng.care.domain.flow.drools.utility.impl.DroolsUtilityImpl;

public class DroolsServiceImpl implements DroolsService {

	private static final Logger LOGGER = LoggerFactory.getLogger(DroolsServiceImpl.class);

	@Autowired
	private DroolsDateUtility droolsDateUtility;

	@Autowired
	private DroolsQueryUtility droolsQueryUtility;

	@Autowired
	private DroolsStringUtility droolsStringUtility;

	@Autowired
	private FlowRowUtility flowRowUtility;

	@Autowired
	private LookupUtility lookupUtility;

	@Autowired
	private ErrorMessageDAO errorMessageDAO;
	
	@Autowired
	private RuleManagerService ruleManagerService;

	@Override
	public List<ValidationBean> validateBeans(List<ValidationBean> beans, KieSession kieSession) throws Exception {
		if (beans != null && !beans.isEmpty()) {
			List<FactHandle> facts = new ArrayList<FactHandle>();
			for (ValidationBean bean : beans) {
				facts.add(kieSession.insert(bean));
			}
			
			kieSession.fireAllRules();
			
			for (FactHandle fact : facts) {
				kieSession.delete(fact);
			}

		}

		return beans;
	}
	
	@Override
	public List<String> checkRule(File file, String filename, String flowId, String versionId) throws IOException {

		File functions = null;
		try {
			functions = ruleManagerService.getFunctions();
		} catch (IOException e) {
			e.printStackTrace();
		}
		
		List<String> errors = new ArrayList<String>();
		KieServices ks = KieServices.Factory.get();
		KieFileSystem kfs = ks.newKieFileSystem();
		
		if(functions != null) {
			Resource resource = ks.getResources().newFileSystemResource(functions).setResourceType(ResourceType.DRL);
			kfs.write(resource);
		}
		
		Resource resource = ks.getResources().newFileSystemResource(file).setResourceType(ResourceType.DRL);
		kfs.write(resource);
		
		// carica tutte le regole del flusso per verificare eventuali duplicazioni tra gli id delle regole
		File[] rules = ruleManagerService.getRules(flowId, versionId);
		if(rules != null) {
			for(File rule : rules) {
				Resource resource2 = ks.getResources().newFileSystemResource(rule).setResourceType(ResourceType.DRL);
				kfs.write(resource2);
			}
		}
		
		KieBuilder kb = ks.newKieBuilder(kfs);
		kb.buildAll();
		if (kb.getResults().hasMessages(Level.ERROR)) {
			for(Message res : kb.getResults().getMessages()) {
				errors.add("Errore nel file " + filename + " : " + res.getText());
			}
		}
		
		return errors;
	}
	
	@Override
	public List<String> checkSingleFile(File file, String filename) {

		List<String> errors = new ArrayList<String>();
		KieServices ks = KieServices.Factory.get();
		KieFileSystem kfs = ks.newKieFileSystem();
		
		Resource resource = ks.getResources().newFileSystemResource(file).setResourceType(ResourceType.DRL);
		kfs.write(resource);
		KieBuilder kb = ks.newKieBuilder(kfs);
		kb.buildAll();
		if (kb.getResults().hasMessages(Level.ERROR)) {
			for(Message res : kb.getResults().getMessages()) {
				errors.add("Errore nel file " + filename + " : " + res.getText());
			}
		}
		
		return errors;
	}
	
	@Override
	public KieSessionWrapper createKieSession(String flowId, String versionId, String ruleType, SecondLevelValidationRequestDO secLevReq) throws Exception {
		KieSession kSession = null;
		KieServices ks = KieServices.Factory.get();
		KieFileSystem kfs = ks.newKieFileSystem();
		
		List<File> allDrlFiles = new ArrayList<File>();
		
		File[] droolsFiles = ruleManagerService.getRules(flowId, versionId, ruleType);
		if(droolsFiles != null && droolsFiles.length > 0) {
			for(File droolsFile : droolsFiles) {
				allDrlFiles.add(droolsFile);
				Resource resource = ks.getResources().newFileSystemResource(droolsFile).setResourceType(ResourceType.DRL);
				kfs.write(resource);
			}
		} else {
			return new KieSessionWrapper(null, null);
		}

		File functions = ruleManagerService.getFunctions();
		if(functions != null) {
			allDrlFiles.add(functions);
			Resource resource = ks.getResources().newFileSystemResource(functions).setResourceType(ResourceType.DRL);
			kfs.write(resource);
		}
		
		KieBuilder kb = ks.newKieBuilder(kfs);

		kb.buildAll();
		if (kb.getResults().hasMessages(Level.ERROR)) {
			// throw new RuntimeException("Build Errors:\n" + kb.getResults().toString());
			
			if(droolsFiles != null) {
				for(File file : droolsFiles) {
					file.delete();
				}
			}
			
			LOGGER.error("******************* ERRREO COMPILAZIONE REGOLE DRL ******************* ");
			LOGGER.error("Build Errors:\n" + kb.getResults().toString());
			return null;
		}

		KieContainer kContainer = ks.newKieContainer(ks.getRepository().getDefaultReleaseId());

		kSession = kContainer.newKieSession();
		
		Map<String, ErrorMessageDO> msgMap = loadErrorMessages();
		DroolsUtility droolsUtility = new DroolsUtilityImpl(msgMap);

		if(droolsFiles != null) {
			kSession.setGlobal("droolsDateUtility", droolsDateUtility);
			kSession.setGlobal("droolsQueryUtility", droolsQueryUtility);
			kSession.setGlobal("droolsStringUtility", droolsStringUtility);
			kSession.setGlobal("droolsUtility", droolsUtility);
			kSession.setGlobal("flowRowUtility", flowRowUtility);
			kSession.setGlobal("lookupUtility", lookupUtility);
			kSession.setGlobal("LOGGER", LOGGER);
			
			if(secLevReq != null) {
				kSession.setGlobal("monthRef", secLevReq.getMonth());
				kSession.setGlobal("yearRef", secLevReq.getYear());
			}
			
		}
		
		File[] allfiles = null;
		if(allDrlFiles != null) {
			allfiles = allDrlFiles.toArray(new File[allDrlFiles.size()]);
		}

		KieSessionWrapper kieSessionWrapper = new KieSessionWrapper(kSession, allfiles);

		return kieSessionWrapper;
	}
	
	@Override
	public void resetLookupMap() {
		lookupUtility.resetLookupMap();
	}
	
	/**
	 * Carica tutti i messaggi di errore utilizzati dalle regole di validazine
	 * @return
	 */
	private Map<String, ErrorMessageDO> loadErrorMessages() {
		Map<String, ErrorMessageDO> msgMap = new HashMap<String, ErrorMessageDO>();
		List<ErrorMessageDO> msgList = errorMessageDAO.findAll();
		if(msgList != null) {
			for (ErrorMessageDO msg : msgList) {
				msgMap.put(msg.getId(), msg);
			}
		}
		return msgMap;
	}

}
