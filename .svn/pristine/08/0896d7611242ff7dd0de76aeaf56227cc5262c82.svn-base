package it.eng.care.domain.flow.core.service.impl;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.data.domain.Example;

import it.eng.care.domain.flow.core.dao.FmSequenceDAO;
import it.eng.care.domain.flow.core.entity.FmSequenceDO;
import it.eng.care.domain.flow.core.service.FmSequenceService;

public class FmSequenceServiceImpl implements FmSequenceService {
	
	@Autowired
	private FmSequenceDAO sequenceDAO;

	@Override
	public synchronized Integer next(Class<?> entity) {
		
		FmSequenceDO example = new FmSequenceDO();
		example.setId(entity.getName());
		
		FmSequenceDO sequenceE = sequenceDAO.findById(Example.of(example).toString()).get();
		if(sequenceE == null) {
			sequenceE = new FmSequenceDO();
			sequenceE.setId(entity.getName());
			sequenceE.setCurrentValue(0);
			sequenceDAO.save(sequenceE);
		}
		
		Integer sequence = sequenceE.getCurrentValue() + 1;
		sequenceE.setCurrentValue(sequence);
		
		return sequence;
	}

}
