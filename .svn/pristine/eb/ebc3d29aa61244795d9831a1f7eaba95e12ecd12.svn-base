	@Override
	public Page<MonitorSdoXlDO> findAll(BaseSearchInput searchInput) {
		int pageSize = searchInput.getValue("pageSize");
		int pageNo = searchInput.getValue("pageNo");
		
		String sortDir = searchInput.getValue("sortDir");
		String sortField = searchInput.getValue("sortField");
		Sort.Order order;
		Sort sort;
		if(sortDir.equals("asc")) {
			order =  new Sort.Order(Sort.Direction.ASC, sortField).ignoreCase();
			sort  =  Sort.by(order);
		}else if(sortDir.equals("desc")){
			order = new Sort.Order(Sort.Direction.DESC, sortField).ignoreCase();
			sort  =  Sort.by(order);
		}else {
			order = new  Sort.Order(Sort.Direction.ASC, "id").ignoreCase();
			sort  =  Sort.by(order);
		}
		Pageable paging =  PageRequest.of(pageNo,pageSize,sort);
		Page<MonitorSdoXlDO> pagedResult = monitorSdoXlDAO.findAllByDeletedOrDeletedIsNull(paging, false);
		return pagedResult;
	}
	
	@Override
	public Page<MonitorSdoXlDO> filterAll(BaseSearchInput searchInput) {
		int pageSize = searchInput.getValue("pageSize");
		int pageNo = searchInput.getValue("pageNo");		
		
		Pageable paging =  PageRequest.of(pageNo,pageSize);
		List<MonitorSdoXlDO> monitorDataList =  monitorSdoXlDAO.filterData(searchInput);
		final int start = (int)paging.getOffset();
		final int end = Math.min((start + paging.getPageSize()), monitorDataList.size());		
		Page<MonitorSdoXlDO> pageTmp = new PageImpl<MonitorSdoXlDO>(monitorDataList.subList(start, end), paging, monitorDataList.size());
		
		return pageTmp;
	}
	
	
	@Override
	public Page<MonitorSdoXlErrorDTO> reatriveAllErrorsByFlussoAndNosologico(BaseSearchInput searchInput){
		String flow = searchInput.getValue("flusso");
		String nosologico = searchInput.getValue("nosologico");
		String presidio = searchInput.getValue("presidio");
		String idEstrazione = searchInput.getValue("idEstrazione");
		int pageSize = searchInput.getValue("pageSize");
		int pageNo = searchInput.getValue("pageNo");
		String nosologicoConditional = searchInput.getValue("nosologicoConditional");
		List<MonitorSdoXlErrorDTO> reatriveAllErrorsByFlussoAndNosologico = errorDAO.searchErrorsByFlowAndNosologico(flow, nosologico, presidio, idEstrazione, nosologicoConditional);
		Pageable paging =  PageRequest.of(pageNo,pageSize);
		if(reatriveAllErrorsByFlussoAndNosologico.size()>0) {			
			final int start = (int)paging.getOffset();
			final int end = Math.min((start + paging.getPageSize()), reatriveAllErrorsByFlussoAndNosologico.size());	
			Page<MonitorSdoXlErrorDTO> pageTmp = 
					new PageImpl<MonitorSdoXlErrorDTO>(reatriveAllErrorsByFlussoAndNosologico.subList(start, end), paging, reatriveAllErrorsByFlussoAndNosologico.size());		
			return pageTmp;
			
		}
		return 	new PageImpl<MonitorSdoXlErrorDTO>(reatriveAllErrorsByFlussoAndNosologico, paging, reatriveAllErrorsByFlussoAndNosologico.size());	
	}

	@Override
	public Integer xmlStatus(String flussId,String nosologico,String presidio) {
