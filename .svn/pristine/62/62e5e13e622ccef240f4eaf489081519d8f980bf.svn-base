package it.eng.care.domain.flow.b2b.model;

import java.util.List;


public class SendDrgDTO {

	String idRequest;
	
    List<KeysDTO> keys;
    
    DrgDTO drg;
    
    String type;


	public String getIdRequest() {
		return idRequest;
	}

	public void setIdRequest(String idRequest) {
		this.idRequest = idRequest;
	}

	public List<KeysDTO> getKeys() {
		return keys;
	}

	public void setKeys(List<KeysDTO> keys) {
		this.keys = keys;
	}

	public DrgDTO getDrg() {
		return drg;
	}

	public void setDrg(DrgDTO drg) {
		this.drg = drg;
	}
    
	public String getType() {
		return type;
	}

	public void setType(String type) {
		this.type = type;
	}
	
}
