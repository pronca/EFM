###DEVELOPE FILE

# HIBERNATE PROPERTIES
#hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
hibernate.dialect=org.hibernate.dialect.H2Dialect
hibernate.default_schema=public
hibernate.jdbc.batch_size=30
hibernate.cache.use_query_cache=false
hibernate.cache.region.factory_class=org.hibernate.cache.jcache.JCacheRegionFactory
hibernate.javax.cache.provider = org.ehcache.jsr107.EhcacheCachingProvider
hibernate.cache.use_second_level_cache=false
hibernate.cache.use_structured_entries=false
hibernate.cache.use_minimal_puts=false
hibernate.search.default.directory_provider=filesystem
hibernate.search.default.indexBase=target/lucenefiles
hibernate.search.lucene_version=LUCENE_CURRENT
hibernate.implicit_naming_strategy.applyTo=*
hibernate.hbm2ddl.auto=update
org.hibernate.envers.audit_table_suffix=_A

# DATASOURCE
#datasource.url=jdbc:postgresql://161.27.202.16:5432/icp2
datasource.url=jdbc:h2:mem:test
#datasource.driver=org.postgresql.Driver
datasource.driver=org.h2.Driver
datasource.username=icp-user
datasource.password=icp-user

### C3P0 
datasource.c3p0.acquire.increment=5
datasource.c3p0.idle.connection.test.period=60
datasource.c3p0.initial.pool.size=1
datasource.c3p0.min.pool.size=1
datasource.c3p0.max.pool.size=15
datasource.c3p0.max.statements=30
datasource.c3p0.debug.unreturned.connection.stack.traces=true
datasource.c3p0.unreturned.connection.timeout=60
