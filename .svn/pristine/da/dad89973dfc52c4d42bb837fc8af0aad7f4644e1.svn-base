package it.eng.care.domain.flow.b2b.model;

import java.util.List;

public class ErrorsDTO {

    List<KeysDTO> keys; // pratica
    List<ErrorFieldsDTO> fields;

    public List<KeysDTO> getKeys() {
        return keys;
    }

    public void setKeys(List<KeysDTO> keys) {
        this.keys = keys;
    }

    public List<ErrorFieldsDTO> getFields() {
        return fields;
    }

    public void setFields(List<ErrorFieldsDTO> fields) {
        this.fields = fields;
    }


}
