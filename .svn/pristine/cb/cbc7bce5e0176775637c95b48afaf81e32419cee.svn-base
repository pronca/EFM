#sonar.projectKey=it.eng.care.domain.flow
#sonar.projectName=it.eng.care.domain.flow
#sonar.sourceEncoding=UTF-8

# Esclusioni globali
sonar.exclusions=**/.svn/**,**/target/**,**/script_liquibase/**
sonar.inclusions=**/src/main/java/**/*.java
sonar.test.inclusions=**/src/test/java/**/*.java

# Moduli
sonar.modules=it.eng.care.domain.flow.api

