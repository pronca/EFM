package it.eng.care.domain.flow.core.enumeration;


public enum ErrorServiceStatusEnum {

    PENDING("IN_ATTESA"),
    SENT("INVIATA"),
    ERROR("ERROR"),
    

    ;


    private String status;

    ErrorServiceStatusEnum(String status) {
        this.status = status;
    }

    public String getStatus() {
        return status;
    }

	
}
