### DATASOURCE H2 ###
datasource.url=jdbc:hsqldb:mem:privacy_access_testdb;
datasource.username=sa
datasource.password=
datasource.driver=org.hsqldb.jdbcDriver
hibernate.dialect=org.hibernate.dialect.H2Dialect
hibernate.hbm2ddl.auto=update

