package it.eng.care.domain.flow.core.dto.FormFlowConfig;

public class FormFlowTableLinkDTO {

    private String id;
    private String idTable;
    private String idTableReferenced;
    private String idFieldTable;
    private String idFieldTableReferenced;
    private String jsonFieldType;
    private String jsonField;
    
    public String getId() {
        return id;
    }

    public void setId(String id) {
        this.id = id;
    }
    
    public String getIdTable() {
        return idTable;
    }

    public void setIdTable(String idTable) {
        this.idTable = idTable;
    }
    
    public String getIdTableReferenced() {
        return idTableReferenced;
    }

    public void setIdTableReferenced(String idTableReferenced) {
        this.idTableReferenced = idTableReferenced;
    }
    
    public String getIdFieldTable() {
        return idFieldTable;
    }

    public void setIdFieldTable(String idFieldTable) {
        this.idFieldTable = idFieldTable;
    }
    
    public String getIdFieldTableReferenced() {
        return idFieldTableReferenced;
    }

    public void setIdFieldTableReferenced(String idFieldTableReferenced) {
        this.idFieldTableReferenced = idFieldTableReferenced;
    }

    public String getJsonFieldType() {
        return jsonFieldType;
    }

    public void setJsonFieldType(String jsonFieldType) {
        this.jsonFieldType = jsonFieldType;
    }

    public String getJsonField() {
        return jsonField;
    }

    public void setJsonField(String jsonField) {
        this.jsonField = jsonField;
    }


}
