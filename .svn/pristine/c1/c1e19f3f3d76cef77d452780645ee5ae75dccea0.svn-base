package it.eng.care.domain.flow.drools.model.lookup;

import java.util.List;
import java.util.Map;

public class LookupTable {

	private String name;

	private String alias;

	private List<LookupRow> rows;

	private Map<String, LookupRow> rowMap;

	public String getName() {
		return name;
	}

	public void setName(String name) {
		this.name = name;
	}

	public String getAlias() {
		return alias;
	}

	public void setAlias(String alias) {
		this.alias = alias;
	}

	public List<LookupRow> getRows() {
		return rows;
	}

	public void setRows(List<LookupRow> rows) {
		this.rows = rows;
	}

	public Map<String, LookupRow> getRowMap() {
		return rowMap;
	}

	public void setRowMap(Map<String, LookupRow> rowMap) {
		this.rowMap = rowMap;
	}

}
