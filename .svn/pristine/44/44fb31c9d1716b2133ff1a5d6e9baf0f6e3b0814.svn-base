package it.eng.care.domain.flow.core.dto;

import java.io.Serializable;
import java.util.Date;

public class FlowDrgDTO implements Serializable {

    private static final long serialVersionUID = 1L;

    private String id;
    private FlowExportRequestDTO extraction;
    private Date sendDate;
    private Date returnDate;
    private String error;
    private String state;
    private String numPratiche;
    
    public FlowDrgDTO() {
    }

	public String getId() {
		return id;
	}

	public void setId(String id) {
		this.id = id;
	}

	public FlowExportRequestDTO getExtraction() {
		return extraction;
	}

	public void setExtraction(FlowExportRequestDTO extraction) {
		this.extraction = extraction;
	}

	public Date getSendDate() {
		return sendDate;
	}

	public void setSendDate(Date sendDate) {
		this.sendDate = sendDate;
	}

	public Date getReturnDate() {
		return returnDate;
	}

	public void setReturnDate(Date returnDate) {
		this.returnDate = returnDate;
	}

	public String getError() {
		return error;
	}

	public void setError(String error) {
		this.error = error;
	}

	public String getState() {
		return state;
	}

	public void setState(String state) {
		this.state = state;
	}

	public String getNumPratiche() {
		return numPratiche;
	}

	public void setNumPratiche(String numPratiche) {
		this.numPratiche = numPratiche;
	}
}
