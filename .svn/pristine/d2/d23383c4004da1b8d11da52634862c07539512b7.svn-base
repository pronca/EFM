package it.eng.care.domain.flow.core.dto;

import java.io.Serializable;
import java.util.HashMap;
import java.util.List;

public class RegionReturnsDTO implements Serializable {

    private static final long serialVersionUID = 1L;

    private List<String> columns;
    private List<HashMap<String,String>> values;
    

    public RegionReturnsDTO() {
    }


	public List<String> getColumns() {
		return columns;
	}


	public void setColumns(List<String> columns) {
		this.columns = columns;
	}


	public List<HashMap<String,String>> getValues() {
		return values;
	}


	public void setValues(List<HashMap<String,String>> values) {
		this.values = values;
	}

}
