package it.eng.care.domain.flow.core.dto.PrivacyManagerDTO;

import java.util.List;

import it.eng.care.domain.flow.core.dto.FormFlowConfig.FormFlowDTO;
import it.eng.care.platform.tool.transport.service.SearchInfo;

public class PMFormFlowView {
	
	private List<FormFlowDTO> formFlowDTO;
	private SearchInfo searchInfo;
	
	public PMFormFlowView() {
	}

	public List<FormFlowDTO> getFormFlowDTO() {
		return formFlowDTO;
	}

	public void setFormFlowDTO(List<FormFlowDTO> formFlowDTO) {
		this.formFlowDTO = formFlowDTO;
	}



	public SearchInfo getSearchInfo() {
		return searchInfo;
	}

	public void setSearchInfo(SearchInfo searchInfo) {
		this.searchInfo = searchInfo;
	}

}
