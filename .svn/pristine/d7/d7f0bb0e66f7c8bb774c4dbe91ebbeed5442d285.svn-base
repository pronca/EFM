                                filterFieldValueDO.setFlowExportRequest(intoObject);
                                list2.add(filterFieldValueDO);
                                filterFieldValueDO2.setConfigurationFilterField(flowConfigurationFilterFieldDO);
                                filterFieldValueDO2.setValue(filterFieldDTO.getNumToValue());
                                filterFieldValueDO2.setFlowExportRequest(intoObject);
                                list2.add(filterFieldValueDO2);
                            }
                            //GESTIONE MULTIVALORE
                            if (filterFieldDTO.getMultiValues() != null && filterFieldDTO.getMultiValues().size() > 0) {
                                for (String value : filterFieldDTO.getMultiValues()) {
                                    FlowConfigurationFilterFieldValueDO filterFieldValueDO3 = new FlowConfigurationFilterFieldValueDO();
                                    filterFieldValueDO3.setConfigurationFilterField(flowConfigurationFilterFieldDO);
                                    filterFieldValueDO3.setValue(value);
                                    filterFieldValueDO3.setFlowExportRequest(intoObject);
                                    list2.add(filterFieldValueDO3);
                                }
                            }
                        }
                    }
                }
            }

        }
        intoObject.setValues(list2);
}
}
