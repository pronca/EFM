--CREO VISTA

  CREATE OR REPLACE FORCE EDITIONABLE VIEW "HC40_FLOW_MANAGER"."FM_INTEGRATION_SERVICE" ("URL", "NOME", "FLUSSO", "ID", "VERTICALE", "ABILITAZIONE", "DT_ENABLE", "DT_DISABLE") AS 
  select FIELD5 URL , FIELD2 NOME , FIELD3 FLUSSO , FIELD1 ID , FIELD4 VERTICALE , FIELD6 ABILITAZIONE , dt_enable, dt_disable from FM_TABGEN_VALUE where tabgen_id = 'FM_INTEGRATION_SERVICE';

