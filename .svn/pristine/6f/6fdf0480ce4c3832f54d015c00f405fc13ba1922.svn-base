package it.eng.care.domain.flow.core.dto;

import java.util.Date;

public class MotherDashboardDTO {

    private String flow;
    private Integer countPraticheThisYear;
    private Integer countPraticheLastYear;
    private String totalThisYear;
    private String totalLastYear;
    private Integer countPrtaicheRegioneThisYear;
    private Integer countPrtaicheRegioneLastYear;
    private String totalRegioneThisYear;
    private String totalRegioneLastYear;
    private Date lastUpdate;


    public String getFlow() {
        return flow;
    }

    public void setFlow(String flow) {
        this.flow = flow;
    }

    public Integer getCountPraticheThisYear() {
        return countPraticheThisYear;
    }

    public void setCountPraticheThisYear(Integer countPraticheThisYear) {
        this.countPraticheThisYear = countPraticheThisYear;
    }

    public Integer getCountPraticheLastYear() {
        return countPraticheLastYear;
    }

    public void setCountPraticheLastYear(Integer countPraticheLastYear) {
        this.countPraticheLastYear = countPraticheLastYear;
    }

    public String getTotalThisYear() {
        return totalThisYear;
    }

    public void setTotalThisYear(String totalThisYear) {
        this.totalThisYear = totalThisYear;
    }

    public String getTotalLastYear() {
        return totalLastYear;
    }

    public void setTotalLastYear(String totalLastYear) {
        this.totalLastYear = totalLastYear;
    }

    public Date getLastUpdate() {
        return lastUpdate;
    }

    public void setLastUpdate(Date lastUpdate) {
        this.lastUpdate = lastUpdate;
    }

	public Integer getCountPrtaicheRegioneThisYear() {
		return countPrtaicheRegioneThisYear;
	}

	public void setCountPrtaicheRegioneThisYear(Integer countPrtaicheRegioneThisYear) {
		this.countPrtaicheRegioneThisYear = countPrtaicheRegioneThisYear;
	}

	public Integer getCountPrtaicheRegioneLastYear() {
		return countPrtaicheRegioneLastYear;
	}

	public void setCountPrtaicheRegioneLastYear(Integer countPrtaicheRegioneLastYear) {
		this.countPrtaicheRegioneLastYear = countPrtaicheRegioneLastYear;
	}

	public String getTotalRegioneThisYear() {
		return totalRegioneThisYear;
	}

	public void setTotalRegioneThisYear(String totalRegioneThisYear) {
		this.totalRegioneThisYear = totalRegioneThisYear;
	}

	public String getTotalRegioneLastYear() {
		return totalRegioneLastYear;
	}

	public void setTotalRegioneLastYear(String totalRegioneLastYear) {
		this.totalRegioneLastYear = totalRegioneLastYear;
	}

	
    

}
