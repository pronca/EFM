package it.eng.care.domain.flow.jobs.look;

import java.net.InetAddress;
import java.net.UnknownHostException;
import java.sql.PreparedStatement;
import java.sql.SQLException;
import java.sql.Timestamp;
import java.time.Instant;

import javax.annotation.PostConstruct;
import javax.sql.DataSource;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.dao.DataIntegrityViolationException;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.jdbc.core.PreparedStatementSetter;
import org.springframework.transaction.PlatformTransactionManager;
import org.springframework.transaction.support.TransactionTemplate;

public class AbstractDatabaseLockService {

	protected String tableName;

	protected JdbcTemplate jdbcTemplate;

	@Autowired
	protected PlatformTransactionManager transactionManager;

	protected TransactionTemplate transactionTemplate;

	public AbstractDatabaseLockService(DataSource datasource, String tableName) {
		super();
		this.tableName = tableName;
		jdbcTemplate = new JdbcTemplate(datasource);
	}

	@PostConstruct
	private void init() {
		transactionTemplate = new TransactionTemplate(transactionManager);
	}

	public boolean insertRecord(String key, Instant until) {
		String sqlInsert = "INSERT INTO " + tableName + "(name, lock_until, locked_at, locked_by) VALUES(?, ?, ?, ?)";
		try {
			// provo a reinserire
			int rows = jdbcTemplate.update(sqlInsert, new PreparedStatementSetter() {
				@Override
				public void setValues(PreparedStatement preparedStatement) throws SQLException {
					preparedStatement.setString(1, key);
					setTimestamp(preparedStatement, 2, until);
					setTimestamp(preparedStatement, 3, Instant.now());
					preparedStatement.setString(4, getHostname());
				}
			});
			return rows > 0;
		} catch (DataIntegrityViolationException e) {
			return false;
		}
	}

	public boolean deleteRecord(String key) {
		String sqlDelete = "delete " + tableName + " WHERE name = ? ";
		// cancello la righa se è scaduta
		int rows = jdbcTemplate.update(sqlDelete, new PreparedStatementSetter() {
			@Override
			public void setValues(PreparedStatement preparedStatement) throws SQLException {
				preparedStatement.setString(1, key);
			}
		});
		return rows > 0;
	}

	public boolean deleteRecord(String key, Instant until) {
		String sqlDelete = "delete " + tableName + " WHERE name = ? AND lock_until <= ? ";
		// cancello la righa se è scaduta
		int rows = jdbcTemplate.update(sqlDelete, new PreparedStatementSetter() {
			@Override
			public void setValues(PreparedStatement preparedStatement) throws SQLException {
				preparedStatement.setString(1, key);
				setTimestamp(preparedStatement, 2, until);
			}
		});
		return rows > 0;
	}

	public boolean updateRecord(String key, Instant until) {
		String sql = "UPDATE " + tableName
				+ " SET lock_until = ?, locked_at = ?, locked_by = ? WHERE name = ? AND lock_until <= ?";

		// cancello la righa se è scaduta
		int updatedRows = jdbcTemplate.update(sql, new PreparedStatementSetter() {

			@Override
			public void setValues(PreparedStatement statement) throws SQLException {
				Instant now = Instant.now();
				setTimestamp(statement, 1, until);
				setTimestamp(statement, 2, now);
				statement.setString(3, getHostname());
				statement.setString(4, key);
				setTimestamp(statement, 5, now);
			}
		});
		return updatedRows > 0;
	}

	private void setTimestamp(PreparedStatement preparedStatement, int patameterIndex, Instant time)
			throws SQLException {
		preparedStatement.setTimestamp(patameterIndex, Timestamp.from(time));
	}

	public static String getHostname() {
		try {
			return InetAddress.getLocalHost().getHostName();
		} catch (UnknownHostException e) {
			return "unknown";
		}
	}
}
