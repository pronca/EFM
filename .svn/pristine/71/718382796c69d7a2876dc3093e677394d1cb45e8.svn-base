package it.eng.care.domain.flow.b2b.model;

import java.io.Serializable;

public class FlowResult implements Serializable {

    private static final long serialVersionUID = 5997892682331382086L;

    private String id;

    public FlowResult(String id) {
        super();
        this.id = id;
    }

    public FlowResult() {
        super();
    }

    public String getId() {
        return id;
    }

    public void setId(String id) {
        this.id = id;
    }

}
