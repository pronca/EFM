package it.eng.care.domain.flow.core.dto;

import java.util.Date;

public class MonitorSdoXlDTO {

	private Integer id;	
	private String flussoId;	
	private String flusso;
	private String presidio;
	private String nosologico;	
	private String nominativo;	
	private String reparto;	
	private Date dataRicovero;	
	private String dataRicoveroString;	
	private Date dataDimissione;	
	private String dataDimissioneString;	
	private String operazione;	
	private String trasmissione;	
	private String protocolloSio;	
	private Date dataInvio;	
	private String dataInvioString;	
	private Date dataRicezione;	
	private String dataRicezioneString;	
	private String esito;
	private Integer status;
	private String idEstrazione;
	
	public MonitorSdoXlDTO() {}
	
	public Integer getId() {
		return id;
	}
	public void setId(Integer id) {
		this.id = id;
	}
	public String getFlussoId() {
		return flussoId;
	}
	public void setFlussoId(String flussoId) {
		this.flussoId = flussoId;
	}
	public String getFlusso() {
		return flusso;
	}
	public void setFlusso(String flusso) {
		this.flusso = flusso;
	}
	public String getPresidio() {
		return presidio;
	}
	public void setPresidio(String presidio) {
		this.presidio = presidio;
	}
	public String getNosologico() {
		return nosologico;
	}
	public void setNosologico(String nosologico) {
		this.nosologico = nosologico;
	}
	public String getNominativo() {
		return nominativo;
	}
	public void setNominativo(String nominativo) {
		this.nominativo = nominativo;
	}
	public String getReparto() {
		return reparto;
	}
	public void setReparto(String reparto) {
		this.reparto = reparto;
	}
	public Date getDataRicovero() {
		return dataRicovero;
	}
	public void setDataRicovero(Date dataRicovero) {
		this.dataRicovero = dataRicovero;
	}
	public Date getDataDimissione() {
		return dataDimissione;
	}
	public void setDataDimissione(Date dataDimissione) {
		this.dataDimissione = dataDimissione;
	}
	public String getOperazione() {
		return operazione;
	}
	public void setOperazione(String operazione) {
		this.operazione = operazione;
	}
	public String getTrasmissione() {
		return trasmissione;
	}
	public void setTrasmissione(String trasmissione) {
		this.trasmissione = trasmissione;
	}
	public String getProtocolloSio() {
		return protocolloSio;
	}
	public void setProtocolloSio(String protocolloSio) {
		this.protocolloSio = protocolloSio;
	}
	public Date getDataInvio() {
		return dataInvio;
	}
	public void setDataInvio(Date dataInvio) {
		this.dataInvio = dataInvio;
	}
	public Date getDataRicezione() {
		return dataRicezione;
	}
	public void setDataRicezione(Date dataRicezione) {
		this.dataRicezione = dataRicezione;
	}
	public String getEsito() {
		return esito;
	}
	public void setEsito(String esito) {
		this.esito = esito;
	}
	public Integer getStatus() {
		
		return status;
	}
	public void setStatus(Integer status) {
		this.status = status;
	}

	public String getIdEstrazione() {
		return idEstrazione;
	}
	public void setIdEstrazione(String idEstrazione) {
		this.idEstrazione = idEstrazione;
	}

	public String getDataRicoveroString() {
		return dataRicoveroString;
	}

	public void setDataRicoveroString(String dataRicoveroString) {
		this.dataRicoveroString = dataRicoveroString;
	}

	public String getDataDimissioneString() {
		return dataDimissioneString;
	}

	public void setDataDimissioneString(String dataDimissioneString) {
		this.dataDimissioneString = dataDimissioneString;
	}

	public String getDataInvioString() {
		return dataInvioString;
	}

	public void setDataInvioString(String dataInvioString) {
		this.dataInvioString = dataInvioString;
	}

	public String getDataRicezioneString() {
		return dataRicezioneString;
	}

	public void setDataRicezioneString(String dataRicezioneString) {
		this.dataRicezioneString = dataRicezioneString;
	}
	
	
}
