eclipse.preferences.version=1
org.eclipse.jdt.apt.aptEnabled=true
org.eclipse.jdt.apt.genSrcDir=target/generated-sources/java
org.eclipse.jdt.apt.genTestSrcDir=target/generated-test-sources/test-annotations
org.eclipse.jdt.apt.processorOptions/querydsl.entityAccessors=true
org.eclipse.jdt.apt.processorOptions/querydsl.useFields=false
